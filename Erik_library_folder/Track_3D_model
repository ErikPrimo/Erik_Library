<Script_3D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
MATERIAL 133
RESOL 64

!----Beggining Width----------------------------------------------------------------------------------------------------------------------------------------------
GOSUB "BegginingWidthHotSpot"
!-----------------------------------------------------------------------------------------------------------------------------------------------------------------

!-------Main Loop Places All Objects------------------------------------------------------------------------------------------------------------------------------
i = 1
!GOSUB "StraightHotSpot"
IF NextLength[1] = 0 AND CurveLeft[1] = 0 AND CurveRight[1] = 0 THEN
	GOSUB "FirstStraight"
	GOSUB "RightHotSpot"
	GOSUB "LeftHotSpot"
ENDIF
WHILE ObjectOrder[i] <> 0 DO
	IF NextLength[i] > ESP 		 THEN ObjectOrder[i+1] = 2
	IF CurveLeft[i]  > ESP 		 THEN ObjectOrder[i+1] = 3
	IF CurveRight[i] > ESP 		 THEN ObjectOrder[i+1] = 4
	IF StraightResizing[i] > ESP THEN ObjectOrder[i+1] = 5
	IF ObjectOrder[i] = 2 THEN
		GOSUB "Straight"
		GOSUB "StraightResizingHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		!IF i < 2 GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 3 THEN
		GOSUB "CurveLeft"
		GOSUB "LeftAngleHotSpot"
		GOSUB "LeftWidthHotSpot"
		!GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 4 THEN
		GOSUB "CurveRight"
		GOSUB "RightAngleHotSpot"
		GOSUB "RightWidthHotSpot"
		!GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 5 THEN
		GOSUB "StraightResizing"
		GOSUB "RightNarrowing"
		GOSUB "LeftNarrowing"
		!GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	"NextIter":
	i = i + 1
ENDWHILE

END
!----Makes The Frist Staright--------------------------------------------------------------------------------------------------------------------------------------------
"FirstStraight":
	EXTRUDE 4, 0, 0, TrackThickness, ExtrudeValues,
			-Width[i]/2,	0,					1,
			Width[i]/2,		0,					1,
			Width[i]/2,		BeginningDistance, 	1,
			-Width[i]/2,	BeginningDistance,	1
	ADDY BeginningDistance
RETURN
!------------------------------------------------------------------------------------------------------------------------------------------------------------------------

!-----Makes The Straight-------------------------------------------------------------------------------------------------------------------------------------------------
"Straight":
	EXTRUDE 4, 0, 0, TrackThickness, ExtrudeValues,
		-Width[i]/2,	0,				 1,
		Width[i]/2,		0,				 1,
		Width[i]/2,		NextLength[i-1], 1,
		-Width[i]/2,	NextLength[i-1], 1
	
	ADDZ TrackThickness
	ADDY TrackThickness/2
	GOSUB "StartSupportsHotSpot"
	DEL 2
	ADDX -Width[i]/2
	IF StartSupports[i] < TrackThickness*3 THEN MiddleHeight = StartSupports[i] ELSE MiddleHeight = TrackThickness*3
	BLOCK Width[i], TrackThickness, MiddleHeight
	BLOCK 1, TrackThickness, StartSupports[i]
	ADDX Width[i]-1
	BLOCK 1, TrackThickness, StartSupports[i]
	DEL 2
	ADDY NextLength[i-1]
	IF NextLength[i-1] > ESP THEN
		ADDZ TrackThickness
		ADDY TrackThickness/2
		GOSUB "EndSupportsHotSpot"
		DEL 2
		ADDX -Width[i]/2
		IF EndSupports[i] < TrackThickness*3 THEN MiddleHeight = EndSupports[i] ELSE MiddleHeight = TrackThickness*3
		BLOCK Width[i], TrackThickness, MiddleHeight
		BLOCK 1, TrackThickness, EndSupports[i]
		ADDX Width[i]-1
		BLOCK 1, TrackThickness, EndSupports[i]
		DEL 2
	ENDIF
RETURN
!----------------------------------------------------------------------------------------------------------------------------------------

"StraightResizing":
	RightNarrowing[i] = RightNarrowing[i] + ESP
	LeftNarrowing[i]  = LeftNarrowing[i] + ESP
	StraightTotalLength = StraightResizing[i-1]
	CurveHeight = StraightTotalLength * 0.60

	MiddleLength = StraightTotalLength / 2
	CurveStart   = MiddleLength - (CurveHeight / 2)
	CurveEnd     = MiddleLength + (CurveHeight / 2)

	MaxAllowedNarrowing = StraightTotalLength * 0.30

	IF RightNarrowing[i] > MaxAllowedNarrowing  THEN RightNarrowing[i] = MaxAllowedNarrowing
	IF RightNarrowing[i] < -MaxAllowedNarrowing THEN RightNarrowing[i] = -MaxAllowedNarrowing
	IF LeftNarrowing[i] > MaxAllowedNarrowing  THEN LeftNarrowing[i] = MaxAllowedNarrowing
	IF LeftNarrowing[i] < -MaxAllowedNarrowing THEN LeftNarrowing[i] = -MaxAllowedNarrowing

	! =========================================================================
	! MAIN TRACK EXTRUDE (Blended S-Curve Path)
	! =========================================================================
	PUT  Width[i]/2,	0,				1
	PUT  Width[i]/2,	CurveStart,		1
	! Right Edge Curve
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio 
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5
		currentX = Width[i]/2 + RightNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex
	PUT  Width[i]/2 + RightNarrowing[i], CurveEnd,    1
	PUT  Width[i]/2 + RightNarrowing[i], StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  CurveEnd,    1
	! Left Edge Curve (Descending)
	FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5
		currentX = -Width[i]/2 - LeftNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex
	PUT -Width[i]/2, CurveStart, 1
	PUT -Width[i]/2, 0,          1
	PUT  Width[i]/2, 0,          1
	EXTRUDE NSP / 3, 0, 0, TrackThickness, ExtrudeValues, GET(NSP)
	
	! =========================================================================
	! TRANSITIONS & WRAP-UP
	! =========================================================================
	ChangedWidth = Width[i+1] + RightNarrowing[i] + LeftNarrowing[i]
	OldWidth = Width[i]
	FOR j = i TO 100
		IF Width[j] = OldWidth THEN
			Width[j] = ChangedWidth
		ENDIF
	NEXT j
	NextLength[i-1] = StraightResizing[i-1]
	ADDY NextLength[i-1]
	ADDX RightNarrowing[i]/2 - LeftNarrowing[i]/2
RETURN

!-----Makes The Right Curving Part-----------------------------------------------------------------------------------------------------------------------------------
"CurveRight":
	Angle = RightAngle[i]
	CurveRadius = Width[i-1]/2 + CurveRight[i-1]
	rCenter = CurveRight[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	InnerRadius = CurveRight[i-1]
	OuterRadius = CurveRight[i-1] + Width[i-1]
	IF Width[i] <= Width[i-1] THEN 
		WidthDifferenceIn = Width[i-1] - Width[i]
		WidthDifferenceOut = 0
		GOSUB "RightTrack"
	ELSE
		WidthDifferenceIn = 0
		WidthDifferenceOut = Width[i] - Width[i-1]
		GOSUB "RightTrack"
		WidthDifferenceOut = Width[i] - Width[i-1]
		ADDY Width[i] - Width[i-1]
	ENDIF
	ADDX CurveRadius - rCenter * COS(Angle)
	ADDY rCenter * SIN(Angle)
	ROTZ -Angle
RETURN

"RightTrack":
	EXTRUDE 8, 0, 0, TrackThickness, ExtrudeValues,
		-Width[i-1]/2,                          0,                                             1,  
		Width[i-1]/2,                           0,                                             1,  
		Width[i-1]/2,                           WidthDifferenceIn,                             1,  
		CurveRadius,                            WidthDifferenceIn,                             900,
		CurveRadius - InnerRadius * COS(Angle), InnerRadius * SIN(Angle) + WidthDifferenceIn,  3001,
		CurveRadius - OuterRadius * COS(Angle), OuterRadius * SIN(Angle) + WidthDifferenceOut, 1,  
		CurveRadius,                            WidthDifferenceOut,                            900,
		-Width[i-1]/2,                          WidthDifferenceOut,                            3001 
	
	IF Angle > 170 THEN
		ADDX CurveRadius
		ADDY CurveRadius - Width[i-1]/2 + 0.5
		GOSUB "InCurveSupportsHotSpot"
		ADDX -1/2
		BLOCK 1, TrackThickness, InCurveSupports[i]
		DEL 1
		ADDY Width[i-1] - 1
		GOSUB "OutCurveSupportsHotSpot"
		ADDX -1/2
		BLOCK 1, TrackThickness, OutCurveSupports[i]
		DEL 4
	ENDIF
RETURN


!-----Makes The Left Curving Part-----------------------------------------------------------------------------------------------------------------------------------
"CurveLeft":
	Angle = LeftAngle[i]
	CurveRadius = -Width[i-1]/2 - CurveLeft[i-1]
	rCenter = CurveLeft[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	InnerRadius = CurveLeft[i-1]
	OuterRadius = CurveLeft[i-1] + Width[i-1]
	IF Width[i] <= Width[i-1] THEN
		WidthDifferenceIn = Width[i-1] - Width[i]
		WidthDifferenceOut = 0
		GOSUB "LeftTrack"
	ELSE
		WidthDifferenceIn = 0
		WidthDifferenceOut = Width[i] - Width[i-1]
		GOSUB "LeftTrack"
		ADDY Width[i] - Width[i-1]
	ENDIF

	ADDX CurveRadius + rCenter * COS(Angle)
	ADDY rCenter * SIN(Angle)
	ROTZ Angle
RETURN


"LeftTrack":
	EXTRUDE 8, 0, 0, TrackThickness, ExtrudeValues,
		Width[i-1]/2,              				0,                              				1,   
		-Width[i-1]/2,              			0,                              				1,   
		-Width[i-1]/2,              			WidthDifferenceIn,                       		1,   
		CurveRadius,                        	WidthDifferenceIn,                       		900, 
		CurveRadius + InnerRadius * COS(Angle), InnerRadius * SIN(Angle) + WidthDifferenceIn, 	3001,
		CurveRadius + OuterRadius * COS(Angle), OuterRadius * SIN(Angle) + WidthDifferenceOut,  1,   
		CurveRadius,                        	WidthDifferenceOut,                             900, 
		Width[i-1]/2,              				WidthDifferenceOut,                             3001

	IF Angle > 170 THEN
		ADDX CurveRadius
		ADDY -CurveRadius - Width[i-1]/2 + 0.5
		GOSUB "InCurveSupportsHotSpot"
		ADDX -1/2
		BLOCK 1, TrackThickness, InCurveSupports[i]
		DEL 1
		ADDY Width[i-1] - 1
		GOSUB "OutCurveSupportsHotSpot"
		ADDX -1/2
		BLOCK 1, TrackThickness, OutCurveSupports[i]
		DEL 4
	ENDIF
RETURN



!---Hot Spots-------------------------------------------------------------------------------------------------------------------------------------
"BegginingWidthHotSpot":
	HOTSPOT  -Width[1]/2,	0,	0, unID, Width[1], 1 : unID = unID + 1
	HOTSPOT   Width[1]/2,	0,	0, unID, Width[1], 2 : unID = unID + 1
	HOTSPOT  -10,			0,	0, unID, Width[1], 3 : unID = unID + 1
RETURN

"RightHotSpot":
	IF CurveLeft[i] < ESP AND StraightResizing[i] < ESP THEN
		HOTSPOT Width[i]/2,  0,	0, unID, CurveRight[i], 1 : unID = unID + 1
		HOTSPOT Width[i]/2,  0, 0, unID, CurveRight[i], 2 : unID = unID + 1
		HOTSPOT Width[i]/2, -1,	0, unID, CurveRight[i], 3 : unID = unID + 1
	ENDIF
RETURN

"RightAngleHotSpot":
	IF CurveRight[i] < ESP AND Width[i] = Width[i-1] THEN 
		centerX = Width[i] / 2 + CurveRight[i-1]
		centerY = 0
		RightRadius = CurveRight[i-1] - 1
		refX = centerX - RightRadius * COS(RightAngle[i])
		refY = centerY - RightRadius * SIN(RightAngle[i])
		HOTSPOT centerX, centerY,  0, unID, RightAngle[i], 518 		: unID = unID + 1
		HOTSPOT refX,    refY,     0, unID, RightAngle[i], 4 + 128  : unID = unID + 1
		HOTSPOT Width[i]/2 + 1, 0, 0, unID, RightAngle[i], 5   		: unID = unID + 1
	ENDIF
RETURN

"RightWidthHotSpot":
	IF CurveRight[i] < ESP AND RightAngle[i] = 90 THEN 
		HOTSPOT -1-Width[i]/2,  0, 0, unID, Width[i], 1 : unID = unID + 1
		HOTSPOT -1-Width[i]/2,  0, 0, unID, Width[i], 2 : unID = unID + 1
		HOTSPOT -1-Width[i]/2-1,0, 0, unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftHotSpot":
	IF CurveRight[i] < ESP AND StraightResizing[i] < ESP THEN
		HOTSPOT -Width[i]/2,  0, 0, unID, CurveLeft[i], 1 : unID = unID + 1
		HOTSPOT -Width[i]/2,  0, 0, unID, CurveLeft[i], 2 : unID = unID + 1
		HOTSPOT -Width[i]/2, -1, 0, unID, CurveLeft[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftAngleHotSpot":
	IF CurveLeft[i] < ESP AND Width[i] = Width[i-1] THEN 
		centerX = - Width[i] / 2 - CurveLeft[i-1]
		centerY = 0
		LeftRadius = CurveLeft[i-1] - 1 
		IF LeftAngle[i] >= 180 THEN LeftAngle[i] = LeftAngle[i] - 1
		refX = centerX + LeftRadius * COS(-LeftAngle[i])
		refY = centerY + LeftRadius * SIN(-LeftAngle[i])
		HOTSPOT centerX, centerY, 		0, unID,	LeftAngle[i], 6 		: unID = unID + 1
		HOTSPOT refX,    refY,    		0, unID,	LeftAngle[i], 4 + 128  : unID = unID + 1
		HOTSPOT - Width[i] / 2 - 1, 0,  0, unID,	LeftAngle[i], 5 		: unID = unID + 1
	ENDIF
RETURN

"LeftWidthHotSpot":
	IF CurveLeft[i] < ESP AND LeftAngle[i] = 90 THEN 
		HOTSPOT 1+Width[i]/2,  0,	0, unID, Width[i], 1 : unID = unID + 1
		HOTSPOT 1+Width[i]/2,  0,	0, unID, Width[i], 2 : unID = unID + 1
		HOTSPOT 1+Width[i]/2+1,0,	0, unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"StraightHotSpot":
	IF NextLength[i] < -ESP THEN NextLength[i] = ESP
	HOTSPOT 0,  0,				0, unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT 0,  NextLength[i], 	0, unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT 0, -1,				0, unID, NextLength[i], 3 : unID = unID + 1
RETURN

"StraightResizingHotSpot":
	IF CurveLeft[i] < ESP AND CurveRight[i] < ESP THEN
		HOTSPOT  Width[i]/4,  0,	0, unID, StraightResizing[i], 1 : unID = unID + 1
		HOTSPOT  Width[i]/4,  0,	0, unID, StraightResizing[i], 2 : unID = unID + 1
		HOTSPOT  Width[i]/4, -1,	0, unID, StraightResizing[i], 3 : unID = unID + 1
	ENDIF
RETURN

"RightNarrowing":
	HOTSPOT  Width[i]/2, 		-StraightResizing[i-1]/4, 0,	unID, RightNarrowing[i], 1 : unID = unID + 1
	HOTSPOT  Width[i]/2, 		-StraightResizing[i-1]/4, 0,	unID, RightNarrowing[i], 2 : unID = unID + 1
	HOTSPOT  Width[i]/2 - 1, 	-StraightResizing[i-1]/4, 0,	unID, RightNarrowing[i], 3 : unID = unID + 1
RETURN

"LeftNarrowing":
	HOTSPOT  -Width[i]/2, 		-StraightResizing[i-1]/4, 0,	unID, LeftNarrowing[i], 1 : unID = unID + 1
	HOTSPOT  -Width[i]/2, 		-StraightResizing[i-1]/4, 0,	unID, LeftNarrowing[i], 2 : unID = unID + 1
	HOTSPOT  -Width[i]/2 + 1, 	-StraightResizing[i-1]/4, 0,	unID, LeftNarrowing[i], 3 : unID = unID + 1
RETURN

"StartSupportsHotSpot":
	HOTSPOT  0, 	0, 0,	unID, StartSupports[i], 1 : unID = unID + 1
	HOTSPOT  0, 	0, 0,	unID, StartSupports[i], 2 : unID = unID + 1
	HOTSPOT  0, 	0, -1,	unID, StartSupports[i], 3 : unID = unID + 1
RETURN
"EndSupportsHotSpot":
	HOTSPOT  0, 	0, 0,	unID, EndSupports[i], 1 : unID = unID + 1
	HOTSPOT  0, 	0, 0,	unID, EndSupports[i], 2 : unID = unID + 1
	HOTSPOT  0, 	0, -1,	unID, EndSupports[i], 3 : unID = unID + 1
RETURN

"InCurveSupportsHotSpot":
	HOTSPOT  0, 	0, 0,	unID, InCurveSupports[i], 1 : unID = unID + 1
	HOTSPOT  0, 	0, 0,	unID, InCurveSupports[i], 2 : unID = unID + 1
	HOTSPOT  0, 	0, -1,	unID, InCurveSupports[i], 3 : unID = unID + 1
RETURN

"OutCurveSupportsHotSpot":
	HOTSPOT  0, 	0, 0,	unID, OutCurveSupports[i], 1 : unID = unID + 1
	HOTSPOT  0, 	0, 0,	unID, OutCurveSupports[i], 2 : unID = unID + 1
	HOTSPOT  0, 	0, -1,	unID, OutCurveSupports[i], 3 : unID = unID + 1
RETURN
!----------------------------------------------------------------------------------------------------------------------------------------
]]>
