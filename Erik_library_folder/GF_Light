<Script_3D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
PoleWidth = 0.03
PoleDepth = 0.065
PoleHeigth = 1.009
PolePlateWidth = 0.09
PolePlateDepth = 0.12
PolePlateHeigth = 0.004

! --- Main Pole ---
BLOCK PoleWidth, PoleDepth, PoleHeigth - PoleWidth/2

! --- Curved Top ---
ADDZ PoleHeigth - PoleWidth/2
ADDX PoleWidth/2
ADDY PoleDepth
ROTX 90
CYLIND PoleDepth, PoleWidth/2
DEL 4

! --- Base Plate ---
ADDX -PolePlateWidth/3
ADDY -PolePlateDepth/4
BLOCK PolePlateWidth, PolePlateDepth, PolePlateHeigth
DEL 2
! --- POSITION AND ROTATE THE LIGHT ---
ADDZ PoleHeigth - PoleWidth/2
ADDX PoleWidth/2  
ADDY PoleDepth / 2

! --- ROTATE THE COORDINATE SYSTEM ---
ADDZ 0.025
ADDY 0.01
ROTZ -90
ROTY 45 
! --- DEBUGBING LINE (Shows the Light Direction) --- 
line_type 2 

ADDX 0.045
ROTY 90
CYLIND PoleDepth+0.01, PoleWidth/2 + 0.01
SPHERE PoleWidth/2 + 0.01
DEL 1
LIGHT   1.0, 1.0, 1.0,            ! RGB (Yellow light)
        1,                      ! Shadow on
        0,                    ! Radius / Source size
        30.0, 40.0,             ! Cone angles (alpha, beta)
        0.3,                    ! Angle falloff
        0.2, 8.0,               ! Distance 1 & 2
        0.0,                    ! Constant intensity (no falloff over distance)
        ADDITIONAL_DATA c4d_gen_Intensity = 1.5,     ! 500% power multiplier (Increase this to 10.0 or 20.0 if you want a blinding spotlight)
                        c4d_gen_Type = "Spot"       ! Directs the physics engine to treat it as a true spotlight

DEL 4
]]>
</Script_3D>

