<![CDATA[
unID = 1
ESP = 0.000001
ExtrudeValues = 0
BeginningDistance = 0.2

LineWidth = 0.05
LineThickness = 0.01
TrackThickness = 0.01
BarrierHeight = .24
ConstantLineMargin = LineMargin

Orietation = 0
DefaultPen = 1
CircleSize = 0.11
TrackColor = 22
TrackMarginColor = 102
CircleColor = 11
TrackMargin = 0.45
TrackMarginLine = 0.25

RightLightDistance = 0
LeftLightDistance = 0
LightMargin = 0.2
LightDistance = 3/2
RightLightBool = 1
LeftLightBool = 0

TempWidth = 7

TopTubeLightHeight = 0.8

IF Sectors THEN
	ExtrudeValues =  1+2+4+16+32
ELSE
	ExtrudeValues =  1+2+4
ENDIF

BREAKPOINT 1
FOR i = 1 TO 120
	!----Sets Every Angle To Default 90 Degrees And Offsets So Its Easier To Set Angle----------------------------------------------------
	IF RightAngle[i] < ESP THEN RightAngle[i] = 90
	IF LeftAngle[i] < ESP THEN LeftAngle[i] = 90
	!-------------------------------------------------------------------------------------------------------------------------------------

	!-----Makes Limits On The Width-------------------------------------------------------------------------------------------------------
	IF Width[i] > ESP THEN Width[i] = MIN(14, MAX(3, Width[i]))
	!-------------------------------------------------------------------------------------------------------------------------------------

	!-----Sets All Widths To The Last Changed One-----------------------------------------------------------------------------------------
	IF Width[i] > ESP AND ABS(Width[i] - TempWidth) > ESP THEN
		IF i = 1 THEN 
			TempWidth = Width[i]
		ELSE
			IF NOT(CurveRight[i-1] < ESP AND CurveLeft[i-1] < ESP) THEN
				TempWidth = Width[i]
			ENDIF
		ENDIF
	ENDIF
	Width[i] = TempWidth
	!-------------------------------------------------------------------------------------------------------------------------------------

	!-----Sets Limit On Angle-------------------------------------------------------------------------------------------------------------
	RightAngle[i] = MIN(180, MAX(0, RightAngle[i]))
	LeftAngle[i]  = MIN(180, MAX(0, LeftAngle[i]))
	!-------------------------------------------------------------------------------------------------------------------------------------
NEXT i
