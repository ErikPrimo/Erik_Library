	BoxMargin = 0.4
	RowDelCounter = 0
	DelCounter = 0
	Rows = 0
	Lines = 0
	FOR j = 1 TO 10
		IF Width[i] > (BoxWidth*2 + BoxMargin*2)*j THEN Rows = j
	NEXT j
	FOR j = 1 TO 6
		IF NextLength[i] > (BoxHeight*2 + BoxMargin*2 + .2)*j THEN Lines = j
	NEXT j

	ADDY -((BoxHeight*2 + BoxMargin*2)*Lines)/2
	DelCounter = DelCounter + 1
	OddEvenSelector = 0
	FOR h = 1 TO Lines
		RowDelCounter = 0
		ADDX (BoxWidth*2 + BoxMargin)/2
		RowDelCounter = RowDelCounter + 1
		ADDX -((BoxWidth*2 + BoxMargin)*Rows)/2
		RowDelCounter = RowDelCounter + 1
		FOR j = 1 TO Rows
			IF j MOD 2 = OddEvenSelector THEN
			EXTRUDE 8, 0, 0, LineThickness, ExtrudeValues,
					-BoxWidth,				0,						1,
					-BoxWidth,				BoxHeight,				1,
					BoxWidth,				BoxHeight, 				1,
					BoxWidth,				0,		 				1,
					BoxWidth-LineWidth,		0,						1,
					BoxWidth-LineWidth,		BoxHeight-LineWidth,	1,
					-BoxWidth+LineWidth,	BoxHeight-LineWidth,	1,
					-BoxWidth+LineWidth,	0,						1
			ENDIF
			ADDX (BoxWidth*2 + BoxMargin)
			RowDelCounter = RowDelCounter + 1
		NEXT j
		OddEvenSelector = NOT(OddEvenSelector)
		DEL RowDelCounter
		ADDY (BoxHeight*2 + BoxMargin*2)
		DelCounter = DelCounter + 1
	NEXT h
	DEL DelCounter
	MATERIAL Asfalt
