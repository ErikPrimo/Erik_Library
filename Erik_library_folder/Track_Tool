!-----Makes The Left Curving Part-----------------------------------------------------------------------------------------------------------------------------------
"CurveLeft":
    GOSUB "CurveBarrierRemoveHotSpot"
    Angle = LeftAngle[i]
    CurveRadius = -Width[i-1]/2 - CurveLeft[i-1]
    rCenter = CurveLeft[i-1] + Width[i]/2 + Width[i-1]-Width[i]
    IF ABS(RemovePart[i]) < Width[i]/2 THEN 
        InnerRadius = CurveLeft[i-1]
        OuterRadius = CurveLeft[i-1] + Width[i-1]
        IF Width[i] <= Width[i-1] THEN
            WidthDifferenceIn = Width[i-1] - Width[i]
            WidthDifferenceOut = 0
            GOSUB "LeftTrack"
            MATERIAL 19
            ChicaneBool = 0
            GOSUB "LeftLines"
            LineMargin = LineMargin + LineWidth*4
            MATERIAL 18
            ChicaneBool = 1
            GOSUB "LeftLines"
            MATERIAL Asfalt
            LineMargin = ConstantLineMargin
        ELSE
            WidthDifferenceIn = 0
            WidthDifferenceOut = Width[i] - Width[i-1]
            GOSUB "LeftTrack"
            MATERIAL 19
            ChicaneBool = 0
            GOSUB "LeftLines"
            LineMargin = LineMargin + LineWidth*4
            MATERIAL 18
            ChicaneBool = 1
            GOSUB "LeftLines"
            MATERIAL Asfalt
            LineMargin = ConstantLineMargin
            ADDY Width[i] - Width[i-1]
        ENDIF
        IF BarrierVisible THEN GOSUB "LeftBarrier"
        IF TopTubeVisible THEN GOSUB "LeftTopTube"
    ENDIF
    GOSUB "LeftCurveLights"

    ADDX CurveRadius + rCenter * COS(Angle)
    ADDY rCenter * SIN(Angle)
    ROTZ Angle
    Orietation = Orietation + Angle
    ROTZ Orietation
    ADDX MoveX[i]
    ADDY MoveY[i]
    ROTZ -Orietation
RETURN

"LeftTopTube":
    TubeFi = 0.080
    PoleHeigth = 1.148 - TubeFi/2
    ADDZ PoleHeigth - TubeFi/4
    ResetTube = 0

    ! --- RIGHT SIDE TOP TUBE (Outer Path - Large Radius) ---
    OuterTubeRadius = OuterRadius + LightMargin + 0.05 + TubeFi/4
    WidthDifferenceOut = 0
    IF Width[i] > Width[i-1] THEN
        WidthDifferenceOut = Width[i] - Width[i-1]
        ADDY Width[i-1] - Width[i]
        ResetTube = 1
    ENDIF

    IF NOT(BarrierRemove[i] > Width[i]/2) THEN
        PUT CurveRadius + OuterTubeRadius, -1, 0, 0
        PUT CurveRadius + OuterTubeRadius,  0, 0, 0
        IF WidthDifferenceOut > ESP THEN PUT CurveRadius + OuterTubeRadius, WidthDifferenceOut, 0, 0

        FOR n = 0 TO SegmentsResolution
            AngleSegment = (n / SegmentsResolution) * LeftAngle[i]
            PUT CurveRadius + OuterTubeRadius * COS(AngleSegment), OuterTubeRadius * SIN(AngleSegment) + WidthDifferenceOut, 0, 0
        NEXT n

        _xEndOut = CurveRadius + OuterTubeRadius * COS(LeftAngle[i]) - SIN(LeftAngle[i])
        _yEndOut = OuterTubeRadius * SIN(LeftAngle[i]) + COS(LeftAngle[i]) + WidthDifferenceOut
        PUT _xEndOut, _yEndOut, 0, 0
        GOSUB "LightTube"
    ENDIF

    IF ResetTube THEN 
        DEL 1
        ResetTube = 0
    ENDIF

    ! --- LEFT SIDE TOP TUBE (Inner Path - Small Radius) ---
    InnerTubeRadius = InnerRadius - LightMargin - 0.05 + TubeFi/4
    WidthDifferenceIn = 0
    IF Width[i] < Width[i-1] THEN WidthDifferenceIn = Width[i-1] - Width[i]
	IF Width[i] > Width[i-1] THEN ADDY Width[i-1] - Width[i]
	
    IF NOT(BarrierRemove[i] < -Width[i]/2) THEN
        PUT CurveRadius + InnerTubeRadius, -1, 0, 0
        PUT CurveRadius + InnerTubeRadius,  0, 0, 0
        IF WidthDifferenceIn > ESP THEN PUT CurveRadius + InnerTubeRadius, WidthDifferenceIn, 0, 0

        FOR n = 0 TO SegmentsResolution
            AngleSegment = (n / SegmentsResolution) * LeftAngle[i]
            PUT CurveRadius + InnerTubeRadius * COS(AngleSegment), InnerTubeRadius * SIN(AngleSegment) + WidthDifferenceIn, 0, 0
        NEXT n

        _xEndIn = CurveRadius + InnerTubeRadius * COS(LeftAngle[i]) - SIN(LeftAngle[i])
        _yEndIn = InnerTubeRadius * SIN(LeftAngle[i]) + COS(LeftAngle[i]) + WidthDifferenceIn
        PUT _xEndIn, _yEndIn, 0, 0
        GOSUB "LightTube"
    ENDIF
	IF Width[i] > Width[i-1] THEN DEL 1
    DEL 1
RETURN

"LeftCurveLights":
    ! Calculate transitional straight lengths based on track width resizing for a left curve
    WideningLength = 0
    NarrowingLength = 0
    IF Width[i] > Width[i-1] THEN WideningLength = Width[i] - Width[i-1]
    IF Width[i] <= Width[i-1] THEN NarrowingLength = Width[i-1] - Width[i]

    ! --- THE FIX: Left is Inner (Small Radius), Right is Outer (Large Radius) ---
    OuterLightRadius = OuterRadius + LightMargin + 0.05 ! Right side (Large radius path)
    InnerLightRadius = InnerRadius - LightMargin - 0.05 ! Left side (Small radius path)

    ! ====================================================================================================
    ! --- LINE 1: OUTER (RIGHT) EDGE LIGHT LINES (Handles Widening Transition + Outer Arc) ---------------
    ! ====================================================================================================
    ADDX CurveRadius   ! Move to the circle center pivot
    ADDY -WideningLength

    LastLightPosOut = 0
    HasPlacedStraightLightsOut = 0

    ! SECTION A: Widening Straight
    IF WideningLength > 0.0001 THEN
        ! Outer Right edge uses RightLightDistance
        FOR j = 0 TO (RightLightDistance + WideningLength) / LightDistance
            CurrentPosRight = RightLightDistance + (LightDistance * j)
            IF CurrentPosRight <= WideningLength THEN
                ADDY CurrentPosRight
                ADDX OuterLightRadius   
                IF TopTubeVisible THEN CALL "GF_TopTube"
                ROTZ -LightAngle                 ! Points straight OUT (Right)
                IF RightLightBool AND LightVisible AND NOT(TopTubeVisible) THEN CALL "GF_Light" PARAMETERS LightStrength = LightStrength
				IF RightLightBool AND LightVisible AND TopTubeVisible THEN 
					ADDZ TopTubeLightHeight
					CALL "FenceLight" PARAMETERS LightStrength = LightStrength
					DEL 1
				ENDIF
                RightLightBool = NOT(RightLightBool)
                DEL 3
                LastLightPosOut = CurrentPosRight
                HasPlacedStraightLightsOut = 1
            ENDIF
        NEXT j
    ENDIF
    ! SECTION B: Outer Arc Curve
    ADDY WideningLength
    OuterCurveArcLength = OuterLightRadius * (Angle * PI / 180)
    OuterAngleStep = (LightDistance / OuterLightRadius) * (180 / PI)
    IF HasPlacedStraightLightsOut THEN
        DistanceToJointOut = WideningLength - LastLightPosOut
        LeftoverDistanceForCurveOut = LightDistance - DistanceToJointOut
        OuterStartAngleOffset = (LeftoverDistanceForCurveOut / OuterLightRadius) * (180 / PI)
    ELSE
        IF RightLightDistance >= WideningLength THEN
            LeftoverDistanceForCurveOut = RightLightDistance - WideningLength
        ELSE
            LeftoverDistanceForCurveOut = LightDistance - ((WideningLength - RightLightDistance) MOD LightDistance)
            IF LeftoverDistanceForCurveOut >= LightDistance THEN LeftoverDistanceForCurveOut = 0
        ENDIF
        OuterStartAngleOffset = (LeftoverDistanceForCurveOut / OuterLightRadius) * (180 / PI)
    ENDIF
    RemainingCurveLengthOut = OuterCurveArcLength - (OuterStartAngleOffset * (PI / 180) * OuterLightRadius)
    IF RemainingCurveLengthOut >= 0 THEN
        OuterTotalSteps = INT(RemainingCurveLengthOut / LightDistance)
        FOR j = 0 TO OuterTotalSteps
            CurrentAngle = OuterStartAngleOffset + (OuterAngleStep * j)
            IF CurrentAngle <= Angle THEN
                ROTZ CurrentAngle      ! Sweeps forward counter-clockwise
                ADDX OuterLightRadius  
                IF TopTubeVisible THEN CALL "GF_TopTube"
                ROTZ -LightAngle                ! Aligns light pointing straight OUT (Right)
                IF RightLightBool AND LightVisible AND NOT(TopTubeVisible) THEN CALL "GF_Light" PARAMETERS LightStrength = LightStrength
				IF RightLightBool AND LightVisible AND TopTubeVisible THEN 
					ADDZ TopTubeLightHeight
					CALL "FenceLight" PARAMETERS LightStrength = LightStrength
					DEL 1
				ENDIF
                RightLightBool = NOT(RightLightBool)
                DEL 3
            ENDIF
        NEXT j
        
        LastArcAngleUsedOut = OuterStartAngleOffset + (OuterAngleStep * OuterTotalSteps)
        ArcDistanceUsedOut = LastArcAngleUsedOut * (PI / 180) * OuterLightRadius
        FinalLeftoverLinearOut = OuterCurveArcLength - ArcDistanceUsedOut
        IF FinalLeftoverLinearOut > 0 THEN
            RightLightDistance = LightDistance - FinalLeftoverLinearOut
        ELSE
            RightLightDistance = 0
        ENDIF
    ELSE
        RightLightDistance = LightDistance - (OuterCurveArcLength - (OuterStartAngleOffset * (PI / 180) * OuterLightRadius))
    ENDIF

    DEL 3 ! Clear Outer Setup Stacks


    ! ====================================================================================================
    ! --- LINE 2: INNER (LEFT) EDGE LIGHT LINES (Handles Narrowing Transition + Inner Arc) ----------------
    ! ====================================================================================================
    ADDX CurveRadius   
    
    AdjustYForWidening = 0
    IF WideningLength > 0.0001 THEN 
        ADDY -WideningLength
        AdjustYForWidening = 1
    ENDIF

    LastLightPosIn = 0
    HasPlacedStraightLightsIn = 0

    ! SECTION A: Narrowing Straight
    IF NarrowingLength > 0.0001 THEN
        ! Inner Left edge uses LeftLightDistance
        FOR k = 0 TO (LeftLightDistance + NarrowingLength) / LightDistance
            CurrentPosLeft = LeftLightDistance + (LightDistance * k)
            IF CurrentPosLeft <= NarrowingLength THEN
                ADDY CurrentPosLeft
                ADDX InnerLightRadius    
                IF TopTubeVisible THEN CALL "GF_TopTube"
                ROTZ LightAngle                ! Points straight OUT (Left)
                IF LeftLightBool AND LightVisible  AND NOT(TopTubeVisible) THEN CALL "GF_Light" PARAMETERS LightStrength = LightStrength
				IF LeftLightBool AND LightVisible AND TopTubeVisible THEN 
					ADDZ TopTubeLightHeight
					CALL "FenceLight" PARAMETERS LightStrength = LightStrength
					DEL 1
				ENDIF
                LeftLightBool = NOT(LeftLightBool)
                DEL 3
                LastLightPosIn = CurrentPosLeft
                HasPlacedStraightLightsIn = 1
            ENDIF
        NEXT k
    ENDIF

    ! SECTION B: Inner Arc Curve
    ADDY NarrowingLength
    
    InnerCurveArcLength = InnerLightRadius * (Angle * PI / 180)
    InnerAngleStep = (LightDistance / InnerLightRadius) * (180 / PI)
    
    IF HasPlacedStraightLightsIn THEN
        DistanceToJointIn = NarrowingLength - LastLightPosIn
        LeftoverDistanceForCurveIn = LightDistance - DistanceToJointIn
        InnerStartAngleOffset = (LeftoverDistanceForCurveIn / InnerLightRadius) * (180 / PI)
    ELSE
        IF LeftLightDistance >= NarrowingLength THEN
            LeftoverDistanceForCurveIn = LeftLightDistance - NarrowingLength
        ELSE
            LeftoverDistanceForCurveIn = LightDistance - ((NarrowingLength - LeftLightDistance) MOD LightDistance)
            IF LeftoverDistanceForCurveIn >= LightDistance THEN LeftoverDistanceForCurveIn = 0
        ENDIF
        InnerStartAngleOffset = (LeftoverDistanceForCurveIn / InnerLightRadius) * (180 / PI)
    ENDIF
    
    RemainingCurveLengthIn = InnerCurveArcLength - (InnerStartAngleOffset * (PI / 180) * InnerLightRadius)
    
    IF RemainingCurveLengthIn >= 0 THEN
        InnerTotalSteps = INT(RemainingCurveLengthIn / LightDistance)
        FOR k = 0 TO InnerTotalSteps
            CurrentAngle = InnerStartAngleOffset + (InnerAngleStep * k)
            IF CurrentAngle <= Angle THEN
                ROTZ CurrentAngle      ! Sweeps forward counter-clockwise
                ADDX InnerLightRadius  
                IF TopTubeVisible THEN CALL "GF_TopTube"
                ROTZ LightAngle               ! Aligns light pointing straight OUT (Left)
				IF NOT(LeftLightBool) AND CurveLeft[i-1] < 4 AND LightVisible AND NOT(TopTubeVisible) THEN CALL "GF_Light" PARAMETERS LightStrength = LightStrength
                IF LeftLightBool AND LightVisible AND NOT(TopTubeVisible) THEN CALL "GF_Light" PARAMETERS LightStrength = LightStrength
				IF LeftLightBool AND LightVisible AND TopTubeVisible THEN 
					ADDZ TopTubeLightHeight
					CALL "FenceLight" PARAMETERS LightStrength = LightStrength
					DEL 1
				ENDIF
                LeftLightBool = NOT(LeftLightBool)
                DEL 3
            ENDIF
        NEXT k
        
        LastArcAngleUsedIn = InnerStartAngleOffset + (InnerAngleStep * InnerTotalSteps)
        ArcDistanceUsedIn = LastArcAngleUsedIn * (PI / 180) * InnerLightRadius
        FinalLeftoverLinearIn = InnerCurveArcLength - ArcDistanceUsedIn
        IF FinalLeftoverLinearIn > 0 THEN
            LeftLightDistance = LightDistance - FinalLeftoverLinearIn
        ELSE
            LeftLightDistance = 0
        ENDIF
    ELSE
        LeftLightDistance = LightDistance - (InnerCurveArcLength - (InnerStartAngleOffset * (PI / 180) * InnerLightRadius))
    ENDIF

    DEL 2 ! Clear Inner Base Setup
    IF AdjustYForWidening THEN DEL 1
RETURN

"LeftTrack":
	EXTRUDE 8, 0, 0, TrackThickness, ExtrudeValues,
		Width[i-1]/2,              				0,                              				1,   
		-Width[i-1]/2,              			0,                              				1,   
		-Width[i-1]/2,              			WidthDifferenceIn,                       		1,   
		CurveRadius,                        	WidthDifferenceIn,                       		900, 
		CurveRadius + InnerRadius * COS(Angle), InnerRadius * SIN(Angle) + WidthDifferenceIn, 	3001,
		CurveRadius + OuterRadius * COS(Angle), OuterRadius * SIN(Angle) + WidthDifferenceOut,  1,   
		CurveRadius,                        	WidthDifferenceOut,                             900, 
		Width[i-1]/2,              				WidthDifferenceOut,                             3001
RETURN

"LeftLines":
ADDZ trackThickness
    prevCurveLeft = CurveLeft[i-1]
    innerTrackRad = prevCurveLeft + lineMargin - lineWidth
    outerTrackRad = prevCurveLeft + lineMargin + lineWidth
    xStartLeft    = curveRadius + innerTrackRad
    xStartRight   = curveRadius + outerTrackRad
    IF chicaneBool THEN
        chicaneOffset = innerTrackRad / 8
    ELSE
        chicaneOffset = 0
    ENDIF
    halfAngle = angle / 2
    outerMid_X = curveRadius + (outerTrackRad + chicaneOffset) * COS(halfAngle)
    outerMid_Y = WidthDifferenceIn + (outerTrackRad + chicaneOffset) * SIN(halfAngle)
    chicaneCenter_X = curveRadius + chicaneOffset * COS(halfAngle)
    chicaneCenter_Y = WidthDifferenceIn + chicaneOffset * SIN(halfAngle)
    EXTRUDE 10, 0, 0, lineThickness, extrudeValues,
        xStartLeft,                               0,                                                  1,
        xStartRight,                              0,                                                  1,
        xStartRight,                              WidthDifferenceIn,                                  1,
        chicaneCenter_X,                          chicaneCenter_Y,                                    900,
        outerMid_X,                               outerMid_Y,                                         3001,
        chicaneCenter_X,                          chicaneCenter_Y,                                    900,
        curveRadius + outerTrackRad * COS(angle), outerTrackRad * SIN(angle) + WidthDifferenceIn,     3001,
        curveRadius + innerTrackRad * COS(angle), innerTrackRad * SIN(angle) + WidthDifferenceIn,     1,
        curveRadius,                              WidthDifferenceIn,                                  900,
        xStartLeft,                               WidthDifferenceIn,                                  3001

	_rOuterInner = CurveLeft[i-1] + Width[i-1] - LineMargin - LineWidth
	_rOuterOuter = CurveLeft[i-1] + Width[i-1] - LineMargin + LineWidth
	_xLineLeftOut  = CurveRadius + _rOuterInner
	_xLineRightOut = CurveRadius + _rOuterOuter
	
	EXTRUDE 8, 0, 0, LineThickness, ExtrudeValues,
		_xLineLeftOut,                 				0,                          					1,    
		_xLineRightOut,                				0,                          					1,    
		_xLineRightOut,                				WidthDifferenceOut,                 			1,    
		CurveRadius,                            	WidthDifferenceOut,                 			900,  
		CurveRadius + _rOuterOuter * COS(Angle), 	_rOuterOuter * SIN(Angle) + WidthDifferenceOut, 3001, 
		CurveRadius + _rOuterInner * COS(Angle), 	_rOuterInner * SIN(Angle) + WidthDifferenceOut, 1,    
		CurveRadius,                            	WidthDifferenceOut,                  			900,  
		_xLineLeftOut,                 				WidthDifferenceOut,                  			3001  
	DEL 1
RETURN

"LeftBarrier":
	ADDZ BarrierHeight
	Reset = 0
	! --- RIGHT SIDE BARRIER (Outer Path) ---
	OuterRadius = CurveLeft[i-1] + Width[i-1] - .05
	! Only shift outer side if the track WIDENS
	WidthDifferenceOut = 0
	IF Width[i] > Width[i-1] THEN
		WidthDifferenceOut = Width[i] - Width[i-1]
		ADDY Width[i-1] - Width[i]
		Reset = 1
	ENDIF
	IF NOT(BarrierRemove[i] > Width[i]/2) THEN 
		PUT CurveRadius + OuterRadius, -1, 0, 0
		PUT CurveRadius + OuterRadius, 0, 0, 0
		IF WidthDifferenceOut > ESP THEN PUT CurveRadius + OuterRadius, WidthDifferenceOut, 0, 0
		FOR n = 0 TO SegmentsResolution
			AngleSegment = (n / SegmentsResolution) * LeftAngle[i]
			PUT CurveRadius + OuterRadius * COS(AngleSegment), OuterRadius * SIN(AngleSegment) + WidthDifferenceOut, 0, 0
		NEXT n
		_xEndOut = CurveRadius + OuterRadius * COS(LeftAngle[i]) - SIN(LeftAngle[i])
		_yEndOut = OuterRadius * SIN(LeftAngle[i]) + COS(LeftAngle[i]) + WidthDifferenceOut
		PUT _xEndOut, _yEndOut, 0, 0
		GOSUB "SlimBarrier"
	ENDIF
	! --- LEFT SIDE BARRIER (Inner Path) ---
	InnerRadius = CurveLeft[i-1] + .05
	! Only shift inner side if the track NARROWS
	WidthDifferenceIn = 0
	IF Width[i] < Width[i-1] THEN WidthDifferenceIn = Width[i-1] - Width[i]
	IF NOT(BarrierRemove[i] < -Width[i]/2) THEN 
		PUT CurveRadius + InnerRadius, -1, 0, 0
		PUT CurveRadius + InnerRadius, 0, 0, 0
		IF WidthDifferenceIn > ESP THEN PUT CurveRadius + InnerRadius, WidthDifferenceIn, 0, 0
		FOR n = 0 TO SegmentsResolution
			AngleSegment = (n / SegmentsResolution) * LeftAngle[i]
			PUT CurveRadius + InnerRadius * COS(AngleSegment), InnerRadius * SIN(AngleSegment) + WidthDifferenceIn, 0, 0
		NEXT n
		_xEndIn = CurveRadius + InnerRadius * COS(LeftAngle[i]) - SIN(LeftAngle[i])
		_yEndIn = InnerRadius * SIN(LeftAngle[i]) + COS(LeftAngle[i]) + WidthDifferenceIn
		PUT _xEndIn, _yEndIn, 0, 0
		GOSUB "Barrier"
	ENDIF
	IF Reset THEN DEL 1
	DEL 1
RETURN
