<Script_3D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
MATERIAL 133
RESOL 64

!----Beggining Width------------------------------------------------------------------------------------------------------------------------------------
GOSUB "BegginingWidthHotSpot"
!----------------------------------------------------------------------------------------------------------------------------------------

!-------HotSpot Line Margin--------------------------------------------------------------------------------------------------------------------
GOSUB "LineMarginHotSpot"
!----------------------------------------------------------------------------------------------------------------------------------------
RightLightDistance = 0
LeftLightDistance = 0
LightMargin = 0.2
LightDistance = 1.5/2
RightLightBool = 1
LeftLightBool = 0
!-------Main Loop Places All Objects--------------------------------------------------------------------------------------------------------------------
i = 1
GOSUB "StraightHotSpot"
IF NextLength[1] = 0 AND CurveLeft[1] = 0 AND CurveRight[1] = 0 THEN
	GOSUB "Straight1"
	GOSUB "RightHotSpot"
	GOSUB "LeftHotSpot"
ENDIF
WHILE ObjectOrder[i] <> 0 DO
	IF NextLength[i] > ESP 		 THEN ObjectOrder[i+1] = 2
	IF CurveLeft[i]  > ESP 		 THEN ObjectOrder[i+1] = 3
	IF CurveRight[i] > ESP 		 THEN ObjectOrder[i+1] = 4
	IF StraightResizing[i] > ESP THEN ObjectOrder[i+1] = 5

	IF ObjectOrder[i] = 2 THEN
		GOSUB "Straight"
		GOSUB "StraightResizingHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		IF i < 2 GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 3 THEN
		GOSUB "CurveLeft"
		GOSUB "LeftAngleHotSpot"
		GOSUB "LeftWidthHotSpot"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 4 THEN
		GOSUB "CurveRight"
		GOSUB "RightAngleHotSpot"
		GOSUB "RightWidthHotSpot"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 5 THEN
		GOSUB "StraightResizing"
		GOSUB "RightNarrowing"
		GOSUB "LeftNarrowing"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	"NextIter":
	IF i = HomeStraight AND HomeStraightActive THEN
		ADDY NextLength[i]/2
		ADDZ TrackThickness
		GOSUB "HomeBox"
		DEL 2
	ENDIF
	i = i + 1
ENDWHILE

END
!----Makes The Frist Staright------------------------------------------------------------------------------------------------------------------------------------
"Straight1":
	EXTRUDE 4, 0, 0, TrackThickness, ExtrudeValues,
			-Width[i]/2,	0,					1,
			Width[i]/2,		0,					1,
			Width[i]/2,		BeginningDistance, 	1,
			-Width[i]/2,	BeginningDistance,	1
	ADDY BeginningDistance
RETURN
!----------------------------------------------------------------------------------------------------------------------------------------

!-----Makes The Straight-----------------------------------------------------------------------------------------------------------------------------------
"Straight":
	GOSUB "BarrierRemoveHotSpot"
	IF ABS(RemovePart[i]) < Width[i]/2  THEN 
		EXTRUDE 4, 0, 0, TrackThickness, ExtrudeValues,
				-Width[i]/2,	0,				 1,
				Width[i]/2,		0,				 1,
				Width[i]/2,		NextLength[i-1], 1,
				-Width[i]/2,	NextLength[i-1], 1
		!-----Lines-----------------------------------------------------------------------------------------------------------------------------------		
		FOR h = 1 TO 2
			IF h = 1 THEN MATERIAL 19
			ADDX -Width[i]/2 + LineMargin
			ADDZ TrackThickness
			EXTRUDE 4, 0, 0, LineThickness, ExtrudeValues,
					-LineWidth,	0,					1,
					LineWidth,	0,					1,
					LineWidth,	NextLength[i-1], 	1,
					-LineWidth,	NextLength[i-1],	1
			DEL 2
			ADDX Width[i]/2 - LineMargin
			ADDZ TrackThickness
			EXTRUDE 4, 0, 0, LineThickness, ExtrudeValues,
					-LineWidth,	0,					1,
					LineWidth,	0,					1,
					LineWidth,	NextLength[i-1], 	1,
					-LineWidth,	NextLength[i-1],	1
			DEL 2
			LineMargin = LineMargin + LineWidth*4
			MATERIAL 18
		NEXT h
		LineMargin = ConstantLineMargin
		MATERIAL 133
		!-----Barriers-----------------------------------------------------------------------------------------------------------------------------------
		IF NextLength[i-1] > 0.0001 AND BarrierVisible THEN
			ADDZ BarrierHeight
			ADDX -Width[i]/2 + .05
			IF NOT(BarrierRemove[i] < -Width[i]/2) THEN
				PUT 0, -1, 					0, 0, 
					0,  0, 					0, 0, 
					0,  NextLength[i-1], 	0, 0, 
					0,  NextLength[i-1]+1, 	0, 0 
				GOSUB "SlimBarrier"
			ENDIF
			ADDX Width[i] - .05*2
			IF NOT(BarrierRemove[i] > Width[i]/2) THEN
				PUT 0, -1, 					0, 0,
					0,  0, 					0, 0,
					0,  NextLength[i-1], 	0, 0,
					0,  NextLength[i-1]+1, 	0, 0
				GOSUB "SlimBarrier"
			ENDIF
			DEL 3
		ENDIF
		!----------------------------------------------------------------------------------------------------------------------------------------

		! --- LINE 1: Right Edge Lights ---
        FOR j = 0 TO (RightLightDistance + NextLength[i-1]) / LightDistance
            CurrentPosRight = RightLightDistance + (LightDistance * j)
            IF CurrentPosRight <= NextLength[i-1] THEN
                ADDY CurrentPosRight
                ADDX Width[i]/2 + LightMargin
                ROTZ -90
                IF RightLightBool AND LightVisible THEN CALL "GF_Light"
				RightLightBool = NOT(RightLightBool)
                DEL 3
            ENDIF
        NEXT j
        ! Update Right Remainder
        OuterRemainder = (RightLightDistance + NextLength[i-1]) MOD LightDistance
        IF OuterRemainder > 0 THEN
            RightLightDistance = LightDistance - OuterRemainder
        ELSE
            RightLightDistance = 0
        ENDIF
        ! --- LINE 2: Left Edge Lights ---
        FOR k = 0 TO (LeftLightDistance + NextLength[i-1]) / LightDistance
            CurrentPosLeft = LeftLightDistance + (LightDistance * k)
            IF CurrentPosLeft <= NextLength[i-1] THEN
                ADDY CurrentPosLeft
                ADDX -Width[i]/2 - LightMargin
                ROTZ 90
                IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
				LeftLightBool = NOT(LeftLightBool)
                DEL 3
            ENDIF
        NEXT k
        ! Update Left Remainder
        InnerRemainder = (LeftLightDistance + NextLength[i-1]) MOD LightDistance
        IF InnerRemainder > 0 THEN
            LeftLightDistance = LightDistance - InnerRemainder
        ELSE
            LeftLightDistance = 0
        ENDIF
	ENDIF
	ADDY NextLength[i-1]
	ROTZ Orietation
	ADDX MoveX[i]
	ADDY MoveY[i]
	ROTZ -Orietation
RETURN
!----------------------------------------------------------------------------------------------------------------------------------------

"StraightResizing":

	GOSUB "StraightResizingBarrierRemoveHotSpot"
	!GOSUB "BarrierRemoveHotSpot"
	RightNarrowing[i] = RightNarrowing[i] + ESP
	LeftNarrowing[i]  = LeftNarrowing[i] + ESP
	StraightTotalLength = StraightResizing[i-1]
	CurveHeight = StraightTotalLength * 0.60

	MiddleLength = StraightTotalLength / 2
	CurveStart   = MiddleLength - (CurveHeight / 2)
	CurveEnd     = MiddleLength + (CurveHeight / 2)
	HalfVerticalHeight = CurveHeight / 2

	MaxAllowedNarrowing = StraightTotalLength * 0.30

	IF RightNarrowing[i] > MaxAllowedNarrowing  THEN RightNarrowing[i] = MaxAllowedNarrowing
	IF RightNarrowing[i] < -MaxAllowedNarrowing THEN RightNarrowing[i] = -MaxAllowedNarrowing
	IF LeftNarrowing[i] > MaxAllowedNarrowing  THEN LeftNarrowing[i] = MaxAllowedNarrowing
	IF LeftNarrowing[i] < -MaxAllowedNarrowing THEN LeftNarrowing[i] = -MaxAllowedNarrowing

	HalfHorizontalShiftRight = RightNarrowing[i] / 2
	CalculatedRadiusRight    = (HalfHorizontalShiftRight^2 + HalfVerticalHeight^2) / (2 * HalfHorizontalShiftRight)
	HalfHorizontalShiftLeft  = LeftNarrowing[i] / 2
	CalculatedRadiusLeft     = (HalfHorizontalShiftLeft^2 + HalfVerticalHeight^2) / (2 * HalfHorizontalShiftLeft)
	SegmentsResolution = 16
	! =========================================================================
	! MAIN TRACK EXTRUDE (Blended S-Curve Path)
	! =========================================================================
	PUT  Width[i]/2, 0, 1
	PUT  Width[i]/2, CurveStart, 1
	! Right Edge Curve
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio 
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5
		currentX = Width[i]/2 + RightNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex
	PUT  Width[i]/2 + RightNarrowing[i], CurveEnd,    1
	PUT  Width[i]/2 + RightNarrowing[i], StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  CurveEnd,    1
	! Left Edge Curve (Descending)
	FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5
		currentX = -Width[i]/2 - LeftNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex
	PUT -Width[i]/2, CurveStart, 1
	PUT -Width[i]/2, 0,          1
	PUT  Width[i]/2, 0,          1
	EXTRUDE NSP / 3, 0, 0, TrackThickness, ExtrudeValues, GET(NSP)
	! =========================================================================
	! MARKING LINES (Perpendicularly Compensated for Constant Line Width)
	! =========================================================================
	ADDZ TrackThickness
	FOR layerIndex = 1 TO 2
		IF layerIndex = 1 THEN MATERIAL 19
		RightLineOuterMargin = LineMargin - LineWidth
		RightLineInnerMargin = LineMargin + LineWidth
		
		! --- RIGHT MARKING LINE PROFILE ---
		PUT Width[i]/2 - RightLineInnerMargin, 0, 1
		PUT Width[i]/2 - RightLineOuterMargin, 0, 1
		PUT Width[i]/2 - RightLineOuterMargin, CurveStart, 1
		
		! Right Line: Outer Edge (Offset Perpendicularly)
		FOR stepIndex = 1 TO SegmentsResolution - 1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			
			! Slope derivative math for normal heading angle
			baseDerivative = (PI / 2) * SIN(progressRatio * 180)
			sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
			blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
			deltaX = RightNarrowing[i] * blendedDerivative
			deltaY = CurveEnd - CurveStart
			
			headingAngle = ATN(deltaX / deltaY)
			currentX = (Width[i]/2 + RightNarrowing[i] * blendedWeight) - RightLineOuterMargin * COS(headingAngle)
			perpendicularY = currentY + RightLineOuterMargin * SIN(headingAngle)
			PUT currentX, perpendicularY, 1
		NEXT stepIndex
		
		PUT Width[i]/2 - RightLineOuterMargin + RightNarrowing[i], CurveEnd, 1
		PUT Width[i]/2 - RightLineOuterMargin + RightNarrowing[i], StraightTotalLength, 1
		PUT Width[i]/2 - RightLineInnerMargin + RightNarrowing[i], StraightTotalLength, 1
		PUT Width[i]/2 - RightLineInnerMargin + RightNarrowing[i], CurveEnd, 1
		
		! Right Line: Inner Edge (Offset Perpendicularly)
		FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			
			baseDerivative = (PI / 2) * SIN(progressRatio * 180)
			sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
			blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
			deltaX = RightNarrowing[i] * blendedDerivative
			deltaY = CurveEnd - CurveStart
			
			headingAngle = ATN(deltaX / deltaY)
			currentX = (Width[i]/2 + RightNarrowing[i] * blendedWeight) - RightLineInnerMargin * COS(headingAngle)
			perpendicularY = currentY + RightLineInnerMargin * SIN(headingAngle)
			PUT currentX, perpendicularY, 1
		NEXT stepIndex
		
		PUT Width[i]/2 - RightLineInnerMargin, CurveStart, 1
		PUT Width[i]/2 - RightLineInnerMargin, 0, 1
		
		EXTRUDE NSP / 3, 0, 0, LineThickness, ExtrudeValues, GET(NSP)

		! --- LEFT MARKING LINE PROFILE ---
		LeftLineOuterMargin = LineMargin - LineWidth
		LeftLineInnerMargin = LineMargin + LineWidth
		
		PUT -Width[i]/2 + LeftLineInnerMargin, 0, 1
		PUT -Width[i]/2 + LeftLineOuterMargin, 0, 1
		PUT -Width[i]/2 + LeftLineOuterMargin, CurveStart, 1
		
		! Left Line: Outer Edge (Offset Perpendicularly)
		FOR stepIndex = 1 TO SegmentsResolution - 1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			
			baseDerivative = (PI / 2) * SIN(progressRatio * 180)
			sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
			blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
			deltaX = -LeftNarrowing[i] * blendedDerivative
			deltaY = CurveEnd - CurveStart
			
			headingAngle = ATN(deltaX / deltaY)
			currentX = (-Width[i]/2 - LeftNarrowing[i] * blendedWeight) + LeftLineOuterMargin * COS(headingAngle)
			perpendicularY = currentY - LeftLineOuterMargin * SIN(headingAngle)
			PUT currentX, perpendicularY, 1
		NEXT stepIndex
		
		PUT -Width[i]/2 + LeftLineOuterMargin - LeftNarrowing[i], CurveEnd, 1
		PUT -Width[i]/2 + LeftLineOuterMargin - LeftNarrowing[i], StraightTotalLength, 1
		PUT -Width[i]/2 + LeftLineInnerMargin - LeftNarrowing[i], StraightTotalLength, 1
		PUT -Width[i]/2 + LeftLineInnerMargin - LeftNarrowing[i], CurveEnd, 1
		
		! Left Line: Inner Edge (Offset Perpendicularly)
		FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			
			baseDerivative = (PI / 2) * SIN(progressRatio * 180)
			sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
			blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
			deltaX = -LeftNarrowing[i] * blendedDerivative
			deltaY = CurveEnd - CurveStart
			
			headingAngle = ATN(deltaX / deltaY)
			currentX = (-Width[i]/2 - LeftNarrowing[i] * blendedWeight) + LeftLineInnerMargin * COS(headingAngle)
			perpendicularY = currentY - LeftLineInnerMargin * SIN(headingAngle)
			PUT currentX, perpendicularY, 1
		NEXT stepIndex
		
		PUT -Width[i]/2 + LeftLineInnerMargin, CurveStart, 1
		PUT -Width[i]/2 + LeftLineInnerMargin, 0, 1
		
		EXTRUDE NSP / 3, 0, 0, LineThickness, ExtrudeValues, GET(NSP)

		LineMargin = LineMargin + LineWidth * 4
		MATERIAL 18
	NEXT layerIndex
	DEL 1
	
	LineMargin = ConstantLineMargin
	MATERIAL 133

	! =========================================================================
	! BARRIERS (Unified Blended S-Curve Logic)
	! =========================================================================
	ADDZ BarrierHeight
	IF NOT(BarrierRemove[i] < -Width[i]/2) THEN
		LeftBarrierStartX = -Width[i]/2 + 0.05
		LeftBarrierEndX   = -Width[i]/2 - LeftNarrowing[i] + 0.05
		
		PUT LeftBarrierStartX, -1, 0, 0
		PUT LeftBarrierStartX,  0, 0, 0
		PUT LeftBarrierStartX,  CurveStart, 0, 0
		FOR stepIndex = 1 TO SegmentsResolution - 1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			currentX = LeftBarrierStartX + (LeftBarrierEndX - LeftBarrierStartX) * blendedWeight
			PUT currentX, currentY, 0, 0
		NEXT stepIndex
		PUT LeftBarrierEndX, CurveEnd, 0, 0
		PUT LeftBarrierEndX, StraightTotalLength, 0, 0
		PUT LeftBarrierEndX, StraightTotalLength + 1, 0, 0
		GOSUB "SlimBarrier"
	ENDIF
	IF NOT(BarrierRemove[i] > Width[i]/2) THEN
		RightBarrierStartX = Width[i]/2 - 0.05
		RightBarrierEndX   = Width[i]/2 + RightNarrowing[i] - 0.05
		PUT RightBarrierStartX, -1, 0, 0
		PUT RightBarrierStartX,  0, 0, 0
		PUT RightBarrierStartX,  CurveStart, 0, 0

		FOR stepIndex = 1 TO SegmentsResolution - 1
			progressRatio = stepIndex / SegmentsResolution
			currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
			
			baseWeight = (1 - COS(progressRatio * 180)) / 2
			sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
			blendedWeight = (baseWeight + sharpWeight) * 0.5
			currentX = RightBarrierStartX + (RightBarrierEndX - RightBarrierStartX) * blendedWeight
			PUT currentX, currentY, 0, 0
		NEXT stepIndex
		PUT RightBarrierEndX, CurveEnd, 0, 0
		PUT RightBarrierEndX, StraightTotalLength, 0, 0
		PUT RightBarrierEndX, StraightTotalLength + 1, 0, 0
		GOSUB "SlimBarrier"
	ENDIF
	DEL 1

	GOSUB "StraightResizingLights"
	
	! =========================================================================
	! TRANSITIONS & WRAP-UP
	! =========================================================================
	ChangedWidth = Width[i+1] + RightNarrowing[i] + LeftNarrowing[i]
	OldWidth = Width[i]
	FOR j = i TO 100
		IF Width[j] = OldWidth THEN
			Width[j] = ChangedWidth
		ENDIF
	NEXT j
	NextLength[i-1] = StraightResizing[i-1]
	ADDY NextLength[i-1]
	ADDX RightNarrowing[i]/2 - LeftNarrowing[i]/2
	ROTZ Orietation
	ADDX MoveX[i]
	ADDY MoveY[i]
	ROTZ -Orietation
RETURN

! ----- LIGHT PLACEMENT FOR RESIZING BLENDED S-CURVE STRAIGHTS ---------------------------------------
"StraightResizingLights":
    ! -------------------------------------------------------------------------
    ! LINE 1: RIGHT EDGE LIGHTS
    ! -------------------------------------------------------------------------
    ! Segment A: Initial Straight (0 to CurveStart)
    FOR j = 0 TO (RightLightDistance + CurveStart) / LightDistance
        CurrentY = RightLightDistance + (LightDistance * j)
        IF CurrentY <= CurveStart THEN
            ADDY CurrentY
            ADDX Width[i]/2 + LightMargin
            ROTZ -90
            IF RightLightBool AND LightVisible THEN CALL "GF_Light"
			RightLightBool = NOT(RightLightBool)
            DEL 3
        ENDIF
    NEXT j
    RightLightDistance = (RightLightDistance + CurveStart) MOD LightDistance
    IF RightLightDistance > 0 THEN RightLightDistance = LightDistance - RightLightDistance

    ! Segment B: Blended S-Curve Transition (CurveStart to CurveEnd)
    CurveSegmentLength = CurveEnd - CurveStart
    CurrentCurveY = 0
    
    ! We loop through the path step-by-step using an adaptive longitudinal spacing length tracker
    WHILE CurrentCurveY <= CurveSegmentLength DO
        progressRatio = CurrentCurveY / CurveSegmentLength
        
        baseWeight = (1 - COS(progressRatio * 180)) / 2
        sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
        blendedWeight = (baseWeight + sharpWeight) * 0.5
        
        baseDerivative = (PI / 2) * SIN(progressRatio * 180)
        sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
        blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
        deltaX = RightNarrowing[i] * blendedDerivative
        deltaY = CurveSegmentLength
        
        headingAngle = ATN(deltaX / deltaY)
        
        ! Placed at the exact requested spacing distance
        IF RightLightDistance <= 0.0001 THEN
            currentX = (Width[i]/2 + RightNarrowing[i] * blendedWeight) + LightMargin * COS(headingAngle)
            perpendicularY = CurveStart + CurrentCurveY - LightMargin * SIN(headingAngle)
            
            ADDX currentX
            ADDY perpendicularY
            ROTZ -90 - headingAngle
            IF RightLightBool AND LightVisible THEN CALL "GF_Light"
			RightLightBool = NOT(RightLightBool)
            DEL 3
            
            RightLightDistance = LightDistance
        ENDIF
        
        ! --- FIX THE SPACING ---
        ! Instead of stepping a flat Y distance, we divide the step by the curve path expansion factor
        ! to keep the physical 2D distance between points perfectly uniform.
        YStep = 0.01 
        PathStep = YStep * SQR(1 + (deltaX / deltaY)^2)
        CurrentCurveY = CurrentCurveY + YStep
        RightLightDistance = RightLightDistance - PathStep
    ENDWHILE
    ! Clean up trailing balance leftover from the while statement
    IF RightLightDistance < 0 THEN RightLightDistance = ABS(RightLightDistance)

    ! Segment C: Terminal Straight (CurveEnd to StraightTotalLength)
    TerminalLengthOut = StraightTotalLength - CurveEnd
    FOR j = 0 TO (RightLightDistance + TerminalLengthOut) / LightDistance
        CurrentDeltaY = RightLightDistance + (LightDistance * j)
        IF CurrentDeltaY <= TerminalLengthOut THEN
            ADDY CurveEnd + CurrentDeltaY
            ADDX Width[i]/2 + RightNarrowing[i] + LightMargin
            ROTZ -90
            IF RightLightBool AND LightVisible THEN CALL "GF_Light"
			RightLightBool = NOT(RightLightBool)
            DEL 3
        ENDIF
    NEXT j
    
    RightLightDistance = (RightLightDistance + TerminalLengthOut) MOD LightDistance
    IF RightLightDistance > 0 THEN
        RightLightDistance = LightDistance - RightLightDistance
    ELSE
        RightLightDistance = 0
    ENDIF


    ! -------------------------------------------------------------------------
    ! LINE 2: LEFT EDGE LIGHTS
    ! -------------------------------------------------------------------------
    ! Segment A: Initial Straight (0 to CurveStart)
    FOR k = 0 TO (LeftLightDistance + CurveStart) / LightDistance
        CurrentY = LeftLightDistance + (LightDistance * k)
        IF CurrentY <= CurveStart THEN
            ADDY CurrentY
            ADDX -Width[i]/2 - LightMargin
            ROTZ 90
            IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
			LeftLightBool = NOT(LeftLightBool)

            DEL 3
        ENDIF
    NEXT k
    LeftLightDistance = (LeftLightDistance + CurveStart) MOD LightDistance
    IF LeftLightDistance > 0 THEN LeftLightDistance = LightDistance - LeftLightDistance

    ! Segment B: Blended S-Curve Transition (CurveStart to CurveEnd)
    CurrentCurveY = 0
    WHILE CurrentCurveY <= CurveSegmentLength DO
        progressRatio = CurrentCurveY / CurveSegmentLength
        
        baseWeight = (1 - COS(progressRatio * 180)) / 2
        sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
        blendedWeight = (baseWeight + sharpWeight) * 0.5
        
        baseDerivative = (PI / 2) * SIN(progressRatio * 180)
        sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
        blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
        deltaX = -LeftNarrowing[i] * blendedDerivative
        deltaY = CurveSegmentLength
        
        headingAngle = ATN(deltaX / deltaY)
        
        if LeftLightDistance <= 0.0001 THEN
            currentX = (-Width[i]/2 - LeftNarrowing[i] * blendedWeight) - LightMargin * COS(headingAngle)
            perpendicularY = CurveStart + CurrentCurveY + LightMargin * SIN(headingAngle)
            
            ADDX currentX
            ADDY perpendicularY
            ROTZ 90 - headingAngle
            IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
			LeftLightBool = NOT(LeftLightBool)
            DEL 3
            
            LeftLightDistance = LightDistance
        ENDIF
        
        ! --- FIX THE SPACING ---
        YStep = 0.01
        PathStep = YStep * SQR(1 + (deltaX / deltaY)^2)
        CurrentCurveY = CurrentCurveY + YStep
        LeftLightDistance = LeftLightDistance - PathStep
    ENDWHILE
    IF LeftLightDistance < 0 THEN LeftLightDistance = ABS(LeftLightDistance)

    ! Segment C: Terminal Straight (CurveEnd to StraightTotalLength)
    TerminalLengthIn = StraightTotalLength - CurveEnd
    FOR k = 0 TO (LeftLightDistance + TerminalLengthIn) / LightDistance
        CurrentDeltaY = LeftLightDistance + (LightDistance * k)
        IF CurrentDeltaY <= TerminalLengthIn THEN
            ADDY CurveEnd + CurrentDeltaY
            ADDX -Width[i]/2 - LeftNarrowing[i] - LightMargin
            ROTZ 90
            IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
			LeftLightBool = NOT(LeftLightBool)
            DEL 3
        ENDIF
    NEXT k
    
    LeftLightDistance = (LeftLightDistance + TerminalLengthIn) MOD LightDistance
    IF LeftLightDistance > 0 THEN
        LeftLightDistance = LightDistance - LeftLightDistance
    ELSE
        LeftLightDistance = 0
    ENDIF
RETURN

!-----Makes The Right Curving Part-----------------------------------------------------------------------------------------------------------------------------------
"CurveRight":
	GOSUB "CurveBarrierRemoveHotSpot"
	Angle = RightAngle[i]
	CurveRadius = Width[i-1]/2 + CurveRight[i-1]
	rCenter = CurveRight[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF ABS(RemovePart[i]) < Width[i]/2  THEN 
		InnerRadius = CurveRight[i-1]
		OuterRadius = CurveRight[i-1] + Width[i-1]
		IF Width[i] <= Width[i-1] THEN 
			WidthDifferenceIn = Width[i-1] - Width[i]
			WidthDifferenceOut = 0
			GOSUB "RightTrack"
			MATERIAL 19
			ChicaneBool = 0
			GOSUB "RightLines"
			LineMargin = LineMargin + LineWidth*4
			MATERIAL 18
			ChicaneBool = 1
			GOSUB "RightLines"
			MATERIAL 133
			LineMargin = ConstantLineMargin
		ELSE
			WidthDifferenceIn = 0
			WidthDifferenceOut = Width[i] - Width[i-1]
			GOSUB "RightTrack"
			WidthDifferenceOut = Width[i] - Width[i-1]
			MATERIAL 19
			ChicaneBool = 0
			GOSUB "RightLines"
			LineMargin = LineMargin + LineWidth*4
			MATERIAL 18
			ChicaneBool = 1
			GOSUB "RightLines"
			MATERIAL 133
			LineMargin = ConstantLineMargin
			ADDY Width[i] - Width[i-1]
		ENDIF
		IF BarrierVisible GOSUB "RightBarrier"
	ENDIF
	GOSUB "RightCurveLights"
	ADDX CurveRadius - rCenter * COS(Angle)
	ADDY rCenter * SIN(Angle)
	ROTZ -Angle
	Orietation = Orietation - Angle
	ROTZ Orietation
	ADDX MoveX[i]
	ADDY MoveY[i]
	ROTZ -Orietation
RETURN
"RightCurveLights":
    ! Calculate transitional straight lengths based on track width resizing
    WideningLength = 0
    NarrowingLength = 0
    IF Width[i] > Width[i-1] THEN WideningLength = Width[i] - Width[i-1]
    IF Width[i] <= Width[i-1] THEN NarrowingLength = Width[i-1] - Width[i]

    ! FIX: Symmetrically align radii definitions for a Right Curve
    OuterLightRadius = OuterRadius + LightMargin  ! Left Edge (Large Radius)
    InnerLightRadius = InnerRadius - LightMargin  ! Right Edge (Small Radius)

    ! ====================================================================================================
    ! --- LINE 1: OUTER (LEFT) EDGE LIGHT LINES (Handles Widening Transition + Outer Arc) ----------------
    ! ====================================================================================================
    ADDX CurveRadius
    ADDY -WideningLength

    LastLightPosOut = 0
    HasPlacedStraightLightsOut = 0

    ! SECTION A: Widening Straight
    IF WideningLength > 0.0001 THEN
        ! FIX: Outer Left edge uses LeftLightDistance
        FOR j = 0 TO (LeftLightDistance + WideningLength) / LightDistance
            CurrentPosLeft = LeftLightDistance + (LightDistance * j)
            IF CurrentPosLeft <= WideningLength THEN
                ADDY CurrentPosLeft
                ADDX -OuterLightRadius
                ROTZ 90
                IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
                LeftLightBool = NOT(LeftLightBool)
                DEL 3
                LastLightPosOut = CurrentPosLeft
                HasPlacedStraightLightsOut = 1
            ENDIF
        NEXT j
    ENDIF

    ! SECTION B: Outer Arc Curve
    ADDY WideningLength
    OuterCurveArcLength = OuterLightRadius * (Angle * PI / 180)
    OuterAngleStep = (LightDistance / OuterLightRadius) * (180 / PI)
    
    IF HasPlacedStraightLightsOut THEN
        DistanceToJointOut = WideningLength - LastLightPosOut
        LeftoverDistanceForCurveOut = LightDistance - DistanceToJointOut
        OuterStartAngleOffset = (LeftoverDistanceForCurveOut / OuterLightRadius) * (180 / PI)
    ELSE
        ! FIX: Use LeftLightDistance for the Outer Left math fallback
        TotalRemainingLinearOut = LeftLightDistance + WideningLength
        LeftoverDistanceForCurveOut = LightDistance - (TotalRemainingLinearOut MOD LightDistance)
        IF LeftoverDistanceForCurveOut >= LightDistance THEN LeftoverDistanceForCurveOut = 0
        OuterStartAngleOffset = (LeftoverDistanceForCurveOut / OuterLightRadius) * (180 / PI)
    ENDIF
    
    RemainingCurveLengthOut = OuterCurveArcLength - (OuterStartAngleOffset * (PI / 180) * OuterLightRadius)
    
    IF RemainingCurveLengthOut >= 0 THEN
        OuterTotalSteps = INT(RemainingCurveLengthOut / LightDistance)
        FOR j = 0 TO OuterTotalSteps
            CurrentAngle = OuterStartAngleOffset + (OuterAngleStep * j)
            IF CurrentAngle <= Angle THEN
                ROTZ -CurrentAngle
                ADDX -OuterLightRadius
                ROTZ 90
                IF LeftLightBool AND LightVisible THEN CALL "GF_Light"
                LeftLightBool = NOT(LeftLightBool)
                DEL 3
            ENDIF
        NEXT j
        
        LastArcAngleUsedOut = OuterStartAngleOffset + (OuterAngleStep * OuterTotalSteps)
        ArcDistanceUsedOut = LastArcAngleUsedOut * (PI / 180) * OuterLightRadius
        FinalLeftoverLinearOut = OuterCurveArcLength - ArcDistanceUsedOut
        IF FinalLeftoverLinearOut > 0 THEN
            LeftLightDistance = LightDistance - FinalLeftoverLinearOut
        ELSE
            LeftLightDistance = 0
        ENDIF
    ELSE
        LeftLightDistance = LightDistance - (OuterCurveArcLength - (OuterStartAngleOffset * (PI / 180) * OuterLightRadius))
    ENDIF

    DEL 3 ! Clear Outer Setup Stacks


    ! ====================================================================================================
    ! --- LINE 2: INNER (RIGHT) EDGE LIGHT LINES (Handles Narrowing Transition + Inner Arc) --------------
    ! ====================================================================================================
    ADDX CurveRadius
    
    AdjustYForWidening = 0
    IF WideningLength > 0.0001 THEN 
        ADDY -WideningLength
        AdjustYForWidening = 1
    ENDIF

    LastLightPosIn = 0
    HasPlacedStraightLightsIn = 0

    ! SECTION A: Narrowing Straight
    IF NarrowingLength > 0.0001 THEN
        ! FIX: Inner Right edge uses RightLightDistance
        FOR k = 0 TO (RightLightDistance + NarrowingLength) / LightDistance
            CurrentPosRight = RightLightDistance + (LightDistance * k)
            IF CurrentPosRight <= NarrowingLength THEN
                ADDY CurrentPosRight
                ADDX -InnerLightRadius
                ROTZ -90
                IF RightLightBool AND LightVisible THEN CALL "GF_Light"
                RightLightBool = NOT(RightLightBool)
                DEL 3
                LastLightPosIn = CurrentPosRight
                HasPlacedStraightLightsIn = 1
            ENDIF
        NEXT k
    ENDIF

    ! SECTION B: Inner Arc Curve
    ADDY NarrowingLength
    
    InnerCurveArcLength = InnerLightRadius * (Angle * PI / 180)
    InnerAngleStep = (LightDistance / InnerLightRadius) * (180 / PI)
    
    IF HasPlacedStraightLightsIn THEN
        DistanceToJointIn = NarrowingLength - LastLightPosIn
        LeftoverDistanceForCurveIn = LightDistance - DistanceToJointIn
        InnerStartAngleOffset = (LeftoverDistanceForCurveIn / InnerLightRadius) * (180 / PI)
    ELSE
        ! FIX: Use RightLightDistance for Inner Right math configurations
        IF RightLightDistance >= NarrowingLength THEN
            LeftoverDistanceForCurveIn = RightLightDistance - NarrowingLength
        ELSE
            LeftoverDistanceForCurveIn = LightDistance - ((NarrowingLength - RightLightDistance) MOD LightDistance)
            IF LeftoverDistanceForCurveIn >= LightDistance THEN LeftoverDistanceForCurveIn = 0
        ENDIF
        InnerStartAngleOffset = (LeftoverDistanceForCurveIn / InnerLightRadius) * (180 / PI)
    ENDIF
    
    RemainingCurveLengthIn = InnerCurveArcLength - (InnerStartAngleOffset * (PI / 180) * InnerLightRadius)
    
    IF RemainingCurveLengthIn >= 0 THEN
        InnerTotalSteps = INT(RemainingCurveLengthIn / LightDistance)
        FOR k = 0 TO InnerTotalSteps
            CurrentAngle = InnerStartAngleOffset + (InnerAngleStep * k)
            IF CurrentAngle <= Angle THEN
                ROTZ -CurrentAngle
                ADDX -InnerLightRadius
                ROTZ -90
                IF RightLightBool AND LightVisible THEN CALL "GF_Light"
                RightLightBool = NOT(RightLightBool)
                DEL 3
            ENDIF
        NEXT k
        
        LastArcAngleUsedIn = InnerStartAngleOffset + (InnerAngleStep * InnerTotalSteps)
        ArcDistanceUsedIn = LastArcAngleUsedIn * (PI / 180) * InnerLightRadius
        FinalLeftoverLinearIn = InnerCurveArcLength - ArcDistanceUsedIn
        IF FinalLeftoverLinearIn > 0 THEN
            RightLightDistance = LightDistance - FinalLeftoverLinearIn
        ELSE
            RightLightDistance = 0
        ENDIF
    ELSE
        RightLightDistance = LightDistance - (InnerCurveArcLength - (InnerStartAngleOffset * (PI / 180) * InnerLightRadius))
    ENDIF

    DEL 2 ! Clears ADDX CurveRadius and ADDY NarrowingLength
    IF AdjustYForWidening THEN DEL 1
RETURN

"RightTrack":
	EXTRUDE 8, 0, 0, TrackThickness, ExtrudeValues,
		-Width[i-1]/2,                          0,                                             1,  
		Width[i-1]/2,                           0,                                             1,  
		Width[i-1]/2,                           WidthDifferenceIn,                             1,  
		CurveRadius,                            WidthDifferenceIn,                             900,
		CurveRadius - InnerRadius * COS(Angle), InnerRadius * SIN(Angle) + WidthDifferenceIn,  3001,
		CurveRadius - OuterRadius * COS(Angle), OuterRadius * SIN(Angle) + WidthDifferenceOut, 1,  
		CurveRadius,                            WidthDifferenceOut,                            900,
		-Width[i-1]/2,                          WidthDifferenceOut,                            3001 
RETURN

"RightLines":
	ADDZ TrackThickness
	InnerRadius = CurveRight[i-1] + LineMargin - LineWidth
	OuterRadius = CurveRight[i-1] + LineMargin + LineWidth
	_xLineLeft  = CurveRadius - OuterRadius
	_xLineRight = CurveRadius - InnerRadius
	IF ChicaneBool AND Angle = 90 THEN Chicane = InnerRadius/8 ELSE Chicane = 0
	EXTRUDE 8, 0, 0, LineThickness, ExtrudeValues,
		_xLineLeft,               				0,                 								1,   
		_xLineRight,              				0,                 								1,   
		_xLineRight,              				WidthDifferenceIn,           					1,   
		CurveRadius,                        	WidthDifferenceIn,           					900, 
		CurveRadius - InnerRadius * COS(Angle), InnerRadius * SIN(Angle) + WidthDifferenceIn, 	3001,
		CurveRadius - OuterRadius * COS(Angle), OuterRadius * SIN(Angle) + WidthDifferenceIn, 	1,   
		CurveRadius - Chicane,        			WidthDifferenceIn + Chicane,     				900, 
		_xLineLeft,               				WidthDifferenceIn,            					3001 

	_rOuterInner = CurveRight[i-1] + Width[i-1] - LineMargin - LineWidth
	_rOuterOuter = CurveRight[i-1] + Width[i-1] - LineMargin + LineWidth
	_xLineLeftOut  = CurveRadius - _rOuterOuter
	_xLineRightOut = CurveRadius - _rOuterInner
	EXTRUDE 8, 0, 0, LineThickness, ExtrudeValues,
		_xLineLeftOut,                			 0,                  								1,    
		_xLineRightOut,               			 0,                  								1,    
		_xLineRightOut,               			 WidthDifferenceOut,            					1,    
		CurveRadius,                             WidthDifferenceOut,            					900,  
		CurveRadius - _rOuterInner * COS(Angle), _rOuterInner * SIN(Angle) + WidthDifferenceOut, 	3001, 
		CurveRadius - _rOuterOuter * COS(Angle), _rOuterOuter * SIN(Angle) + WidthDifferenceOut, 	1,    
		CurveRadius,                           	 WidthDifferenceOut,            					900,  
		_xLineLeftOut,               			 WidthDifferenceOut,            					3001  
	DEL 1
RETURN

"RightBarrier":
	ADDZ BarrierHeight
	Segments = 12
	Reset = 0
	! --- LEFT SIDE BARRIER (Outer Path) ---
	OuterRadius = CurveRight[i-1] + Width[i-1] - .05
	
	! Only shift outer side if the track WIDENS
	WidthDifferenceOut = 0
	IF Width[i] > Width[i-1] THEN
		WidthDifferenceOut = Width[i] - Width[i-1]
		ADDY Width[i-1] - Width[i]
		Reset = 1
	ENDIF
	IF NOT(BarrierRemove[i] < -Width[i]/2) THEN
		PUT CurveRadius - OuterRadius, -1, 0, 0
		PUT CurveRadius - OuterRadius, 0, 0, 0
		IF WidthDifferenceOut > ESP THEN PUT CurveRadius - OuterRadius, WidthDifferenceOut, 0, 0
		FOR n = 0 TO Segments
			AngleSegment = (n / Segments) * RightAngle[i]
			PUT CurveRadius - OuterRadius * COS(AngleSegment), OuterRadius * SIN(AngleSegment) + WidthDifferenceOut, 0, 0
		NEXT n
		_xEndOut = CurveRadius - OuterRadius * COS(RightAngle[i]) + SIN(RightAngle[i])
		_yEndOut = OuterRadius * SIN(RightAngle[i]) + COS(RightAngle[i]) + WidthDifferenceOut
		PUT _xEndOut, _yEndOut, 0, 0
		GOSUB "SlimBarrier"
	ENDIF
		! --- RIGHT SIDE BARRIER (Inner Path) ---
	InnerRadius = CurveRight[i-1] + .05
		WidthDifferenceIn = 0
	IF Width[i] < Width[i-1] THEN WidthDifferenceIn = Width[i-1] - Width[i]
	IF NOT(BarrierRemove[i] > Width[i]/2) THEN
		PUT CurveRadius - InnerRadius, -1, 0, 0
		PUT CurveRadius - InnerRadius, 0, 0, 0
		IF WidthDifferenceIn > ESP THEN PUT CurveRadius - InnerRadius, WidthDifferenceIn, 0, 0
		FOR n = 0 TO Segments
			AngleSegment = (n / Segments) * RightAngle[i]
			PUT CurveRadius - InnerRadius * COS(AngleSegment), InnerRadius * SIN(AngleSegment) + WidthDifferenceIn, 0, 0
		NEXT n
		_xEndIn = CurveRadius - InnerRadius * COS(RightAngle[i]) + SIN(RightAngle[i])
		_yEndIn = InnerRadius * SIN(RightAngle[i]) + COS(RightAngle[i]) + WidthDifferenceIn
		PUT _xEndIn, _yEndIn, 0, 0
		GOSUB "Barrier"
	ENDIF
	IF Reset THEN DEL 1
	DEL 1
RETURN
