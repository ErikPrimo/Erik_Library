"RightHotSpot":
	IF CurveLeft[i] < ESP AND StraightResizing[i] < ESP THEN
		HOTSPOT Width[i]/2,  0,	0, unID, CurveRight[i], 1 : unID = unID + 1
		HOTSPOT Width[i]/2,  0, 0, unID, CurveRight[i], 2 : unID = unID + 1
