<Script_2D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
SET FILL "Solid Fill"
PEN 1

!----Beggining Width------------------------------------------------------------------------------------------------------------------------------------
GOSUB "BegginingWidthHotSpot"

IF ColorCircles THEN
	POLY2_B 2, 1+2+4,
		TrackColor, 0,
		Width[1]/2,            0,   900,
		CircleSize,            360, 4001
ENDIF
!----------------------------------------------------------------------------------------------------------------------------------------

i = 1
GOSUB "StraightHotSpot"
IF NextLength[1] = 0 AND CurveLeft[1] = 0 AND CurveRight[1] = 0 THEN
	GOSUB "Straight1"
	GOSUB "RightHotSpot"
	GOSUB "LeftHotSpot"
ENDIF
WHILE ObjectOrder[i] <> 0 DO
	IF NextLength[i] > ESP			THEN ObjectOrder[i+1] = 2
	IF CurveLeft[i]  > ESP			THEN ObjectOrder[i+1] = 3
	IF CurveRight[i] > ESP			THEN ObjectOrder[i+1] = 4
	IF StraightResizing[i] > ESP	THEN ObjectOrder[i+1] = 5

	IF ObjectOrder[i] = 2 THEN
		GOSUB "Straight"
		GOSUB "StraightResizingHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		IF i < 2 GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 3 THEN
		GOSUB "CurveLeft"
		GOSUB "LeftAngleHotSpot"
		GOSUB "LeftWidthHotSpot"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 4 THEN
		GOSUB "CurveRight"
		GOSUB "RightAngleHotSpot"
		GOSUB "RightWidthHotSpot"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	IF ObjectOrder[i] = 5 THEN
		GOSUB "StraightResizing"
		GOSUB "RightNarrowing"
		GOSUB "LeftNarrowing"
		GOSUB "StraightHotSpot"
		ObjectOrder[i+1] = 2 
		IF NextLength[i] <= 0 THEN NextLength[i] = ESP
		GOTO "NextIter"
	ENDIF

	"NextIter":
	i = i + 1
ENDWHILE
ROT2 -Orietation
TEXT2 0, -2, STR(TotalLength, 10, 3) + " m"

END

"Straight1":
	POLY2_B 5, 1+2+4,
		TrackColor, 0,
		-Width[i]/2,    0,                  1,
		Width[i]/2,     0,                  1,
		Width[i]/2,     BeginningDistance,  1,
		-Width[i]/2,    BeginningDistance,  1,
		-Width[i]/2,    0,                 -1
	ADD2 0, BeginningDistance
RETURN

"Straight":
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		POLY2_B 5, 1+2+4, 
			TrackColor, 0,
			-Width[i]/2,    0,               1,
			Width[i]/2,     0,               1,
			Width[i]/2,     NextLength[i-1], 1,
			-Width[i]/2,    NextLength[i-1], 1,
			-Width[i]/2,    0,              -1
		LINE2 0, 0,		0, NextLength[i-1]
		ADD2 Width[i]/2, 0
		FOR j = 1 TO 2
			POLY2_B 5, 1+2+4,
				TrackMarginColor, 0,
				0,    			0,               1,
				TrackMargin,    0,               1,
				TrackMargin,    NextLength[i-1], 1,
				0,    			NextLength[i-1], 1,
				0,    			0,              -1
			IF j = 1 THEN LINE2 TrackMarginLine,				0,	TrackMarginLine,				NextLength[i-1]
			IF j = 2 THEN LINE2 TrackMargin - TrackMarginLine,	0,	TrackMargin - TrackMarginLine,	NextLength[i-1]
			ADD2 -Width[i]-TrackMargin, 0
		NEXT j
		DEL 3

	ENDIF
	TotalLength = TotalLength + NextLength[i-1]
	ADD2 0, NextLength[i-1]
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"StraightResizing":
	RightNarrowing[i] = RightNarrowing[i] + ESP
	LeftNarrowing[i]  = LeftNarrowing[i] + ESP

	StraightTotalLength = StraightResizing[i-1]
	CurveHeight = StraightTotalLength * 0.60

	MiddleLength = StraightTotalLength / 2
	CurveStart   = MiddleLength - (CurveHeight / 2)
	CurveEnd     = MiddleLength + (CurveHeight / 2)
	HalfVerticalHeight = CurveHeight / 2
	
	! --- DYNAMIC +/- 30% CONSTRAINT ---
	MaxAllowedNarrowing = StraightTotalLength * 0.30

	IF RightNarrowing[i] > MaxAllowedNarrowing  THEN RightNarrowing[i] = MaxAllowedNarrowing
	IF RightNarrowing[i] < -MaxAllowedNarrowing THEN RightNarrowing[i] = -MaxAllowedNarrowing
	IF LeftNarrowing[i] > MaxAllowedNarrowing  THEN LeftNarrowing[i] = MaxAllowedNarrowing
	IF LeftNarrowing[i] < -MaxAllowedNarrowing THEN LeftNarrowing[i] = -MaxAllowedNarrowing
	
	SegmentsResolution = 16

	PUT  Width[i]/2, 0, 1
	PUT  Width[i]/2, CurveStart, 1

	! Right Edge Blended S-Curve Loop
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		currentX = Width[i]/2 + RightNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex

	PUT  Width[i]/2 + RightNarrowing[i], CurveEnd,    1
	PUT  Width[i]/2 + RightNarrowing[i], StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],  CurveEnd,    1

	! Left Edge Blended S-Curve Loop (Descending)
	FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		currentX = -Width[i]/2 - LeftNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex

	PUT -Width[i]/2, CurveStart, 1
	PUT -Width[i]/2, 0,          1

	_track2DPoints = NSP / 3
	POLY2_B _track2DPoints, 1+2+4, TrackColor, 0, GET(NSP)

	LINE2 0, 0, RightNarrowing[i]/2 - LeftNarrowing[i]/2, StraightResizing[i-1]

	ChangedWidth = Width[i+1] + RightNarrowing[i] + LeftNarrowing[i]
	OldWidth = Width[i]
	FOR j = i TO 100
		IF Width[j] = OldWidth THEN
			Width[j] = ChangedWidth
		ENDIF
	NEXT j
	! --- RESTORED MOVEMENT CORRECTIONS ---
	ADD2 RightNarrowing[i]/2, 0
	ADD2 -LeftNarrowing[i]/2, 0
	! =========================================================================
	! RIGHT TRACK MARGIN
	! =========================================================================
	ADD2 -RightNarrowing[i], 0
	PUT Width[i]/2, 0, 1
	PUT Width[i]/2 + TrackMargin, 0, 1
	PUT Width[i]/2 + TrackMargin, CurveStart, 1
	! Outer Margin Curve (With Perpendicular math calculation)
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		baseDerivative = (PI / 2) * SIN(progressRatio * 180)
		sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
		blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
		deltaX = RightNarrowing[i] * blendedDerivative
		deltaY = CurveEnd - CurveStart

		headingAngle = ATN(deltaX / deltaY)
		currentX = (Width[i]/2 + RightNarrowing[i] * blendedWeight) + TrackMargin * COS(headingAngle)
		perpendicularY = currentY - TrackMargin * SIN(headingAngle)
		PUT currentX, perpendicularY, 1
	NEXT stepIndex

	PUT Width[i]/2 + TrackMargin + RightNarrowing[i], CurveEnd,    1
	PUT Width[i]/2 + TrackMargin + RightNarrowing[i], StraightTotalLength, 1
	PUT Width[i]/2 + RightNarrowing[i],               StraightTotalLength, 1
	PUT Width[i]/2 + RightNarrowing[i],               CurveEnd,    1

	! Inner Edge (Matches Track Edge Loop Perfectly)
	FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		currentX = Width[i]/2 + RightNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex

	PUT Width[i]/2, CurveStart, 1
	PUT Width[i]/2, 0,          1
	POLY2_B NSP / 3, 1+2+4, TrackMarginColor, 0, GET(NSP)
	DEL 1
	! =========================================================================
	! LEFT TRACK MARGIN
	! =========================================================================
	ADD2 LeftNarrowing[i], 0
	
	PUT -Width[i]/2, 0, 1
	PUT -Width[i]/2 - TrackMargin, 0, 1
	PUT -Width[i]/2 - TrackMargin, CurveStart, 1

	! Outer Margin Curve (With Perpendicular math calculation)
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		baseDerivative = (PI / 2) * SIN(progressRatio * 180)
		sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
		blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
		deltaX = -LeftNarrowing[i] * blendedDerivative
		deltaY = CurveEnd - CurveStart

		headingAngle = ATN(deltaX / deltaY)
		currentX = (-Width[i]/2 - LeftNarrowing[i] * blendedWeight) - TrackMargin * COS(headingAngle)
		perpendicularY = currentY + TrackMargin * SIN(headingAngle)
		PUT currentX, perpendicularY, 1
	NEXT stepIndex

	PUT -Width[i]/2 - TrackMargin - LeftNarrowing[i], CurveEnd,    1
	PUT -Width[i]/2 - TrackMargin - LeftNarrowing[i], StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],               StraightTotalLength, 1
	PUT -Width[i]/2 - LeftNarrowing[i],               CurveEnd,    1

	! Inner Edge (Matches Track Edge Loop Perfectly)
	FOR stepIndex = SegmentsResolution - 1 TO 1 STEP -1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		currentX = -Width[i]/2 - LeftNarrowing[i] * blendedWeight
		PUT currentX, currentY, 1
	NEXT stepIndex

	PUT -Width[i]/2, CurveStart, 1
	PUT -Width[i]/2, 0,          1

	_lmPoints = NSP / 3
	POLY2_B _lmPoints, 1+2+4, TrackMarginColor, 0, GET(NSP)
	DEL 1


	! =========================================================================
	! RIGHT MARGIN LINE
	! =========================================================================
	ADD2 -RightNarrowing[i], 0
	
	PUT Width[i]/2 + TrackMarginLine, 0, 1
	PUT Width[i]/2 + TrackMarginLine, CurveStart, 1
	
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		baseDerivative = (PI / 2) * SIN(progressRatio * 180)
		sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
		blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
		deltaX = RightNarrowing[i] * blendedDerivative
		deltaY = CurveEnd - CurveStart

		headingAngle = ATN(deltaX / deltaY)
		currentX = (Width[i]/2 + RightNarrowing[i] * blendedWeight) + TrackMarginLine * COS(headingAngle)
		perpendicularY = currentY - TrackMarginLine * SIN(headingAngle)
		PUT currentX, perpendicularY, 1
	NEXT stepIndex
	
	PUT Width[i]/2 + RightNarrowing[i] + TrackMarginLine, CurveEnd,    1
	PUT Width[i]/2 + RightNarrowing[i] + TrackMarginLine, StraightTotalLength, 1
	
	_rmLinePoints = NSP / 3
	POLY2_B _rmLinePoints, 1, TrackMarginColor, 0, GET(NSP)
	DEL 1


	! =========================================================================
	! LEFT MARGIN LINE
	! =========================================================================
	ADD2 LeftNarrowing[i], 0
	
	PUT -Width[i]/2 - TrackMarginLine, 0, 1
	PUT -Width[i]/2 - TrackMarginLine, CurveStart, 1
	
	FOR stepIndex = 1 TO SegmentsResolution - 1
		progressRatio = stepIndex / SegmentsResolution
		currentY = CurveStart + (CurveEnd - CurveStart) * progressRatio
		baseWeight = (1 - COS(progressRatio * 180)) / 2
		sharpWeight = baseWeight^2 * (3 - 2 * baseWeight)
		blendedWeight = (baseWeight + sharpWeight) * 0.5

		baseDerivative = (PI / 2) * SIN(progressRatio * 180)
		sharpDerivative = 2 * baseWeight * baseDerivative * (3 - 2 * baseWeight) + (baseWeight^2) * (-2 * baseDerivative)
		blendedDerivative = (baseDerivative + sharpDerivative) * 0.5
		deltaX = -LeftNarrowing[i] * blendedDerivative
		deltaY = CurveEnd - CurveStart

		headingAngle = ATN(deltaX / deltaY)
		currentX = (-Width[i]/2 - LeftNarrowing[i] * blendedWeight) - TrackMarginLine * COS(headingAngle)
		perpendicularY = currentY + TrackMarginLine * SIN(headingAngle)
		PUT currentX, perpendicularY, 1
	NEXT stepIndex
	
	PUT -Width[i]/2 - LeftNarrowing[i] - TrackMarginLine, CurveEnd,    1
	PUT -Width[i]/2 - LeftNarrowing[i] - TrackMarginLine, StraightTotalLength, 1
	
	_lmLinePoints = NSP / 3
	POLY2_B _lmLinePoints, 1, TrackMarginColor, 0, GET(NSP)
	DEL 1

	TotalLength = TotalLength + StraightTotalLength
	ADD2 0, StraightTotalLength
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"CurveRight":
	Angle = RightAngle[i]
	CurveRadius = Width[i-1]/2 + CurveRight[i-1]
	rCenter = CurveRight[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		IF Width[i] <= Width[i-1] THEN
			InnerMargin = Width[i-1]-Width[i]
			OuterMargin = 0
			GOSUB "RightTrack"
			GOSUB "RightTrackMargin"
			LINE2 0, 0,	
				0, (Width[i-1]-Width[i])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 CurveRadius, (Width[i-1]-Width[i])/2,
				CurveRadius, 180-Angle, 180
			TotalLength = TotalLength + (Angle * PI * ABS(CurveRadius) / 180)
		ELSE
			InnerMargin = 0
			OuterMargin = Width[i]-Width[i-1]
			GOSUB "RightTrack"
			GOSUB "RightTrackMargin"
			LINE2 0, 0,
				0, (Width[i] - Width[i-1])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 CurveRadius, (Width[i] - Width[i-1])/2,
				CurveRadius, Angle, 180
			TotalLength = TotalLength + (Angle * PI * ABS(CurveRadius) / 180)
			ADD2 0, Width[i] - Width[i-1]
		ENDIF
	ENDIF
	ADD2 CurveRadius - rCenter * COS(Angle), rCenter * SIN(Angle)
	ROT2 -Angle
	Orietation = Orietation - Angle
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN
"RightTrack":
	POLY2_B 9, 1+2+4,
		TrackColor, 0,
		-Width[i-1]/2,                                     			0,                                                   		1,
		Width[i-1]/2,                                     			0,                                                   		1,
		Width[i-1]/2,                                     			InnerMargin,                                 				1,
		CurveRadius,                                               	InnerMargin,                                 				900,
		CurveRadius - CurveRight[i-1] * COS(Angle),                 CurveRight[i-1] * SIN(Angle) + InnerMargin,  				3001,
		CurveRadius - (CurveRight[i-1] + Width[i-1]) * COS(Angle),  (CurveRight[i-1] + Width[i-1]) * SIN(Angle) + OuterMargin,  1,
		CurveRadius,                                               	OuterMargin,                                                900,
		-Width[i-1]/2,                                     			OuterMargin,                                                3001,
		-Width[i-1]/2,                                     			OuterMargin,                                                -1
RETURN
"RightTrackMargin":
	POLY2_B 7, 1+2+4,
		TrackMarginColor, 0,
		Width[i-1]/2,                                              	0,                                							1,
		Width[i-1]/2 + TrackMargin,                                	0,                                							1,
		Width[i-1]/2 + TrackMargin,                                	InnerMargin,                                				1,
		CurveRadius,                                               	InnerMargin,                                				900,
		CurveRadius - (CurveRight[i-1] - TrackMargin) * COS(Angle), (CurveRight[i-1] - TrackMargin) * SIN(Angle) + InnerMargin, 3001,
		CurveRadius - CurveRight[i-1] * COS(Angle),                	CurveRight[i-1] * SIN(Angle) + InnerMargin, 				1,
		Width[i-1]/2,                                              	InnerMargin,                                				3001

	POLY2_B 8, 1+2+4,
		TrackMarginColor, 0,
		-Width[i-1]/2,                                                             0,                                                                                  1,
		-Width[i-1]/2 - TrackMargin,                                               0,                                                                                  1,
		-Width[i-1]/2 - TrackMargin,                                               OuterMargin,                                                                        1,
		CurveRadius,                                                               OuterMargin,                                                                        900,
		CurveRadius - (CurveRight[i-1] + Width[i-1] + TrackMargin) * COS(Angle),   (CurveRight[i-1] + Width[i-1] + TrackMargin) * SIN(Angle) + OuterMargin,            3001,
		CurveRadius - (CurveRight[i-1] + Width[i-1]) * COS(Angle),                 (CurveRight[i-1] + Width[i-1]) * SIN(Angle) + OuterMargin,                          1,
		CurveRadius,                                                               OuterMargin,                                                                        900,
		-Width[i-1]/2,                                                             OuterMargin,                                                                        3001

LINE2 Width[i-1]/2 + TrackMarginLine, 0,    
			Width[i-1]/2 + TrackMarginLine, InnerMargin  

		ARC2 CurveRadius, InnerMargin,
			CurveRight[i-1] - TrackMarginLine, 180 - Angle, 180

		LINE2 -Width[i-1]/2 - TrackMarginLine, 0,   
			-Width[i-1]/2 - TrackMarginLine, OuterMargin   

		ARC2 CurveRadius, OuterMargin,
			CurveRight[i-1] + Width[i-1] + TrackMarginLine, 180 - Angle, 180
RETURN

"CurveLeft":
	Angle = LeftAngle[i]
	CurveRadius = -Width[i-1]/2 - CurveLeft[i-1]
	rCenter = CurveLeft[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		IF Width[i] <= Width[i-1] THEN
			InnerMargin = Width[i-1]-Width[i]
			OuterMargin = 0
			GOSUB "LeftTrack"
			GOSUB "LeftTrackMargin"
			LINE2 0, 0,
				0, (Width[i-1] - Width[i])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 CurveRadius, (Width[i-1] - Width[i])/2,
				-CurveRadius, 0, Angle
			TotalLength = TotalLength + (Angle * PI * ABS(CurveRadius) / 180)

		ELSE
			InnerMargin = 0
			OuterMargin = Width[i]-Width[i-1]
			GOSUB "LeftTrack"
			GOSUB "LeftTrackMargin"
			LINE2 0, 0,	
				0, (Width[i] - Width[i-1])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 CurveRadius, (Width[i] - Width[i-1])/2,
				-CurveRadius, 0, Angle
			TotalLength = TotalLength + (Angle * PI * ABS(CurveRadius) / 180)

			ADD2 0, Width[i] - Width[i-1]
		ENDIF
	ENDIF
	ADD2 CurveRadius + rCenter * COS(Angle), rCenter * SIN(Angle)
	ROT2 Angle
	Orietation = Orietation + Angle
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"LeftTrack":
	POLY2_B 9, 1+2+4,
		TrackColor, 0,
			Width[i-1]/2,												0,															1,
		-Width[i-1]/2,													0,															1,
		-Width[i-1]/2,													InnerMargin,												1,
			CurveRadius,												InnerMargin, 												900,
			CurveRadius + CurveLeft[i-1] * COS(Angle), 					CurveLeft[i-1] * SIN(Angle) + InnerMargin,					3001,
			CurveRadius + (CurveLeft[i-1] + Width[i-1]) * COS(Angle),	(CurveLeft[i-1] + Width[i-1]) * SIN(Angle) + OuterMargin,	1,
			CurveRadius,												OuterMargin, 												900,
			Width[i-1]/2,												OuterMargin,												3001,
			Width[i-1]/2,												OuterMargin,												-1
RETURN

"LeftTrackMargin":
	POLY2_B 7, 1+2+4,
		TrackMarginColor, 0,
		-Width[i-1]/2,                                              0,                                								1,
		-Width[i-1]/2 - TrackMargin,                                0,                                								1,
		-Width[i-1]/2 - TrackMargin,                                InnerMargin,                                					1,
		CurveRadius,                                               	InnerMargin,                                					900,
		CurveRadius + (CurveLeft[i-1] - TrackMargin) * COS(Angle), 	(CurveLeft[i-1] - TrackMargin) * SIN(Angle) + InnerMargin, 		3001,
		CurveRadius + CurveLeft[i-1] * COS(Angle),                	CurveLeft[i-1] * SIN(Angle) + InnerMargin, 						1,
		-Width[i-1]/2,                                              InnerMargin,                                					3001

POLY2_B 8, 1+2+4,
		TrackMarginColor, 0,
		Width[i-1]/2,                                                              0,                                                                     	1,
		Width[i-1]/2 + TrackMargin,                                                0,                                                                     	1,
		Width[i-1]/2 + TrackMargin,                                                OuterMargin,                                                           	1,
		CurveRadius,                                                               OuterMargin,                                                           	900,
		CurveRadius + (CurveLeft[i-1] + Width[i-1] + TrackMargin) * COS(Angle),    (CurveLeft[i-1] + Width[i-1] + TrackMargin) * SIN(Angle) + OuterMargin,	3001,
		CurveRadius + (CurveLeft[i-1] + Width[i-1]) * COS(Angle),                  (CurveLeft[i-1] + Width[i-1]) * SIN(Angle) + OuterMargin,              	1,
		CurveRadius,                                                               OuterMargin,                                                           	900,
		Width[i-1]/2,                                                              OuterMargin,                                                           	3001


		LINE2 -Width[i-1]/2 - TrackMarginLine, 0,	
			-Width[i-1]/2 - TrackMarginLine, InnerMargin	

		ARC2 CurveRadius, InnerMargin,
			CurveLeft[i-1] - TrackMarginLine, 0, Angle

		LINE2 Width[i-1]/2 + TrackMarginLine, 0,	
			Width[i-1]/2 + TrackMarginLine, OuterMargin	

		ARC2 CurveRadius, OuterMargin,
			CurveLeft[i-1] + Width[i-1] + TrackMarginLine, 0, Angle
RETURN

"BegginingWidthHotSpot":
	HOTSPOT2  -Width[1]/2,		0,	unID, Width[1], 1 : unID = unID + 1
	HOTSPOT2   Width[1]/2,		0,	unID, Width[1], 2 : unID = unID + 1
	HOTSPOT2  -1-Width[1]/2,	0,	unID, Width[1], 3 : unID = unID + 1
RETURN

"RightHotSpot":
	IF CurveLeft[i] < ESP AND StraightResizing[i] < ESP THEN
		HOTSPOT2  Width[i]/2,  0,	unID, CurveRight[i], 1 : unID = unID + 1
		HOTSPOT2  Width[i]/2,  0,	unID, CurveRight[i], 2 : unID = unID + 1
		HOTSPOT2  Width[i]/2, -1,	unID, CurveRight[i], 3 : unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				8, 0,
				Width[i]/2,              0, 900,
				CircleSize,            360, 4001
		ENDIF
	ENDIF
RETURN

"RightAngleHotSpot":
	IF CurveRight[i] < ESP AND Width[i] = Width[i-1] THEN
		centerX = Width[i] / 2 + CurveRight[i-1]
		centerY = 0
		RightRadius = CurveRight[i-1] - 1
		refX = centerX - RightRadius * COS(RightAngle[i])
		refY = centerY - RightRadius * SIN(RightAngle[i])
		HOTSPOT2 centerX, centerY,  unID, RightAngle[i], 518 		: unID = unID + 1
		HOTSPOT2 refX,    refY,     unID, RightAngle[i], 4 + 128  	: unID = unID + 1
		HOTSPOT2 Width[i]/2 + 1, 0, unID, RightAngle[i], 5   		: unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				6, 0,
				1+Width[i]/2,            0, 900,
				CircleSize,            360, 4001
		ENDIF
	ENDIF
RETURN

"RightWidthHotSpot":
	IF CurveRight[i] < ESP AND RightAngle[i] = 90 THEN
		HOTSPOT2 -1-Width[i]/2,   0,	unID, Width[i], 1 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2,   0,	unID, Width[i], 2 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2-1, 0,	unID, Width[i], 3 : unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				3, 0,
				-1-Width[i]/2, 0, 900,
				CircleSize,    360, 4001
		ENDIF
	ENDIF
RETURN

"LeftHotSpot":
	IF CurveRight[i] < ESP AND StraightResizing[i] < ESP THEN
		HOTSPOT2 -Width[i]/2, 0,	unID, CurveLeft[i], 1 : unID = unID + 1
		HOTSPOT2 -Width[i]/2, 0,	unID, CurveLeft[i], 2 : unID = unID + 1
		HOTSPOT2 -Width[i]/2, -1,	unID, CurveLeft[i], 3 : unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				5, 0,
				-Width[i]/2,	0,   900,
				CircleSize, 	360, 4001
		ENDIF
	ENDIF
RETURN

"LeftAngleHotSpot":
	IF CurveLeft[i] < ESP AND Width[i] = Width[i-1] THEN 
		centerX = - Width[i] / 2 - CurveLeft[i-1]
		centerY = 0
		LeftRadius = CurveLeft[i-1] - 1 
		refX = centerX + LeftRadius * COS(-LeftAngle[i])
		refY = centerY + LeftRadius * SIN(-LeftAngle[i])
		HOTSPOT2 centerX, centerY, 		unID, LeftAngle[i], 6 		: unID = unID + 1
		HOTSPOT2 refX,    refY,    		unID, LeftAngle[i], 4 + 128 : unID = unID + 1
		HOTSPOT2 - Width[i] / 2 - 1, 0, unID, LeftAngle[i], 5 		: unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				6, 0,
				-1-Width[i]/2, 0, 	900,
				CircleSize,    360, 4001
		ENDIF
	ENDIF
RETURN

"LeftWidthHotSpot":
	IF CurveLeft[i] < ESP AND LeftAngle[i] = 90 THEN
		HOTSPOT2  1+Width[i]/2,   0,	unID, Width[i], 1 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2,   0,	unID, Width[i], 2 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2+1, 0,	unID, Width[i], 3 : unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				3, 0,
				1+Width[i]/2, 0, 	900,
				CircleSize,   360, 4001
		ENDIF
	ENDIF
RETURN

"StraightHotSpot":
	HOTSPOT2 0,  0,				unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT2 0,  NextLength[i],	unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT2 0, -1,				unID, NextLength[i], 3 : unID = unID + 1
	IF GLOB_CONTEXT = 22 THEN
		LINE2  0, 	0, 					 0, NextLength[i]
		LINE2 -0.3, NextLength[i] - 0.3, 0, NextLength[i]
		LINE2  0.3, NextLength[i] - 0.3, 0, NextLength[i]
	ENDIF
	IF ColorCircles THEN
		POLY2_B 2, 1+2+4,
				4, 0,
				0,			NextLength[i],	900,
				CircleSize,	360, 			4001
	ENDIF
RETURN

"StraightHotSpot1":
	HOTSPOT2 0,  0,					unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT2 0,  BeginningDistance,	unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT2 0, -1,					unID, NextLength[i], 3 : unID = unID + 1
	IF ColorCircles THEN
		POLY2_B 2, 1+2+4,
				4, 0,
				0,			BeginningDistance,	900,
				CircleSize,	360, 				4001
	ENDIF
RETURN

"RemoveHotSpot":
	HOTSPOT2  0,  NextLength[i]-1,	unID, RemovePart[i], 1 : unID = unID + 1
	HOTSPOT2  0,  NextLength[i]-1,	unID, RemovePart[i], 2 : unID = unID + 1
	HOTSPOT2 -1,  NextLength[i]-1,	unID, RemovePart[i], 3 : unID = unID + 1
	GOSUB "MoveSegmentHotSpot"
	IF ABS(RemovePart[i]) > Width[i]/2 THEN GOTO "NextIter"
RETURN

"RemoveCornerHotSpot":
	HOTSPOT2  0, -1,	unID, RemovePart[i], 1 : unID = unID + 1
	HOTSPOT2  0, -1,	unID, RemovePart[i], 2 : unID = unID + 1
	HOTSPOT2 -1, -1,	unID, RemovePart[i], 3 : unID = unID + 1
	GOSUB "MoveSegmentHotSpot"
	IF ABS(RemovePart[i]) > Width[i]/2 THEN GOTO "NextIter"
RETURN

"MoveSegmentHotSpot":
	IF ABS(RemovePart[i]) > Width[i]/2 THEN
		ROT2 RightAngle[i]
		ROT2 Orietation
		HOTSPOT2  0,    0,	unID, MoveY[i], 1 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveY[i], 2 : unID = unID + 1
		HOTSPOT2 -100,  0,	unID, MoveY[i], 3 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveX[i], 1 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveX[i], 2 : unID = unID + 1
		HOTSPOT2  0,  100,	unID, MoveX[i], 3 : unID = unID + 1
		ROT2 -Orietation
		DEL 3
	ENDIF
RETURN

"StraightResizingHotSpot":
	IF CurveLeft[i] < ESP AND CurveRight[i] < ESP THEN
		HOTSPOT2  Width[i]/4,  0,	unID, StraightResizing[i], 1 : unID = unID + 1
		HOTSPOT2  Width[i]/4,  0,	unID, StraightResizing[i], 2 : unID = unID + 1
		HOTSPOT2  Width[i]/4, -1,	unID, StraightResizing[i], 3 : unID = unID + 1
		IF ColorCircles THEN
			POLY2_B 2, 1+2+4,
				80, 0,
				Width[i]/4,              0, 900,
				CircleSize,            360, 4001
		ENDIF
	ENDIF
RETURN

"RightNarrowing":
	HOTSPOT2  Width[i]/2, 		-StraightResizing[i-1]/4,	unID, RightNarrowing[i], 1 : unID = unID + 1
	HOTSPOT2  Width[i]/2, 		-StraightResizing[i-1]/4,	unID, RightNarrowing[i], 2 : unID = unID + 1
	HOTSPOT2  Width[i]/2 - 1, 	-StraightResizing[i-1]/4,	unID, RightNarrowing[i], 3 : unID = unID + 1
	IF ColorCircles THEN
		POLY2_B 2, 1+2+4,
			75, 0,
			Width[i]/2,            -StraightResizing[i-1]/4, 900,
			CircleSize,            360, 					 4001
	ENDIF
RETURN
"LeftNarrowing":
	HOTSPOT2  -Width[i]/2, 		-StraightResizing[i-1]/4,	unID, LeftNarrowing[i], 1 : unID = unID + 1
	HOTSPOT2  -Width[i]/2, 		-StraightResizing[i-1]/4,	unID, LeftNarrowing[i], 2 : unID = unID + 1
	HOTSPOT2  -Width[i]/2 + 1, 	-StraightResizing[i-1]/4,	unID, LeftNarrowing[i], 3 : unID = unID + 1
	IF ColorCircles THEN
		POLY2_B 2, 1+2+4,
			77, 0,
			-Width[i]/2,           -StraightResizing[i-1]/4, 900,
			CircleSize,            360, 					 4001
	ENDIF
RETURN
]]>
