! 	cx = Width/2 + CurveRight[i-1]

! 	ARC2 cx,0,rIn,180,180-Angle
! 	ARC2 cx,0,rOut,180,180-Angle

! 	ADD2 cx - rCenter * COS(Angle), rCenter * SIN(Angle)
! 	ROT2 -Angle
! RETURN


