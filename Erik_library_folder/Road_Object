<Script_3D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
MATERIAL 133
DIM StraightLength[100]
DIM CurvetWidth[100]
FOR i = 1 TO 100
	IF RightAngle[i] = 0 THEN RightAngle[i] = 90
NEXT i

FOR i = 1 TO 100
	IF LeftAngle[i] = 0 THEN LeftAngle[i] = 90
NEXT i

FOR i = 1 TO 100
    IF Width[i] <> 0 THEN Width[i] = MIN(14, MAX(3, Width[i]))
NEXT i

TempWidth = Width[1]
IF TempWidth = 0 THEN TempWidth = 7

h = 1
WHILE h <= 100 DO
	IF Width[h] > 0 AND Width[h] <> TempWidth THEN
		TempWidth = Width[h]
	ENDIF
	Width[h] = TempWidth
	h = h + 1
ENDWHILE

FOR i = 1 TO 100
	RightAngle[i] = MIN(180, MAX(0, RightAngle[i]))
	LeftAngle[i]  = MIN(180, MAX(0, LeftAngle[i]))
NEXT i


HOTSPOT  -Width[1]/2,	0,	0, unID, Width[1], 1 : unID = unID + 1
HOTSPOT   Width[1]/2,	0,	0, unID, Width[1], 2 : unID = unID + 1
HOTSPOT  -10,		0,	0, unID, Width[1], 3 : unID = unID + 1

CurvetWidth[1] = Width[1]

i = 1
WHILE ObjectOrder[i] <> 0 DO
	IF ObjectOrder[i] = 1 THEN
		GOSUB "StraightHotSpot1"
		GOSUB "Straight1"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
	ENDIF
	IF NextLength[i] > 0 THEN  ObjectOrder[i+1] = 2
	IF CurveLeft[i] > 0  THEN  ObjectOrder[i+1] = 3
	IF CurveRight[i] > 0 THEN  ObjectOrder[i+1] = 4
	IF ObjectOrder[i] = 2 THEN
		GOSUB "Straight"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	IF ObjectOrder[i] = 3 THEN
		GOSUB "CurveLeft"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "LeftAngleHotSpot"
		GOSUB "LeftWidthHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	IF ObjectOrder[i] = 4 THEN
		GOSUB "CurveRight"
		GOSUB "RightHotSpot"
		GOSUB "RightAngleHotSpot"
		GOSUB "RightWidthHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	"NextIter":
	i = i + 1
ENDWHILE

END

"Straight1":
	EXTRUDE 4, 0, 0, 0.1, 1+2+4+16+32,
			-Width[i]/2,	0,	1,
			 Width[i]/2,	0,	1,
			 Width[i]/2,	1, 	1,
			-Width[i]/2,	1,	1
	ADDY 1
RETURN

"Straight":
	EXTRUDE 4, 0, 0, 0.1, 1+2+4+16+32,
			-Width[i]/2,	0,					1,
			 Width[i]/2,	0,					1,
			 Width[i]/2,	NextLength[i-1], 	1,
			-Width[i]/2,	NextLength[i-1],	1

	ADDY NextLength[i-1]
RETURN

"CurveRight":
	Angle = RightAngle[i]
	cx = Width[i-1]/2 + CurveRight[i-1]
	rCenter = CurveRight[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF Width[i] <= Width[i-1] THEN 
		EXTRUDE 8,0,0,0.1,1+2+4+16+32,
			-Width[i-1]/2,										0,													1,
			 Width[i-1]/2,										0,													1,
			 Width[i-1]/2,										Width[i-1]-Width[i],								1,
			 cx,												Width[i-1]-Width[i], 								900,  
			 cx - CurveRight[i-1] * COS(Angle), 				CurveRight[i-1] * SIN(Angle) + Width[i-1]-Width[i], 3001,
			 cx - (CurveRight[i-1] + Width[i-1]) * COS(Angle),	(CurveRight[i-1] + Width[i-1]) * SIN(Angle),		1,
			 cx,												0, 													900,
			-Width[i-1]/2,										0,													3001
	ELSE
		EXTRUDE 7,0,0,0.1,1+2+4+16+32,
			-Width[i-1]/2,										0,													1,
			 Width[i-1]/2,										0,													1,
			 cx,												0, 													900,  
			 cx - CurveRight[i-1] * COS(Angle), 				CurveRight[i-1] * SIN(Angle), 						3001,
			 cx - (CurveRight[i-1] + Width[i-1]) * COS(Angle),	(CurveRight[i-1] + Width[i-1]) * SIN(Angle) + Width[i] - Width[i-1],		1,
			 cx,												Width[i] - Width[i-1], 											900,
			!-Width[i-1]/2,										0,													1,
			-Width[i-1]/2,										Width[i] - Width[i-1],											3001
		ADDY Width[i] - Width[i-1]
	ENDIF
	ADDX cx - rCenter * COS(Angle)
	ADDY rCenter * SIN(Angle)
	ROTZ -Angle
RETURN

"CurveLeft":
	Angle = LeftAngle[i]
	cx = -Width[i]/2 - CurveLeft[i-1]
	rCenter = CurveLeft[i-1] + Width[i]/2
	EXTRUDE 7,0,0,0.1,1+2+4+16+32,
		 Width[i]/2,										0,												1,
		-Width[i]/2,										0,												1,
		 cx,												0, 												900,  
		 cx + CurveLeft[i-1] * COS(Angle), 					CurveLeft[i-1] * SIN(Angle), 					3001,
		 cx + (CurveLeft[i-1] + Width[i]) * COS(Angle),		(CurveLeft[i-1] + Width[i]) * SIN(Angle),		1,
		 cx,												0, 												900,
		 Width[i]/2,										0,												3001
	ADDX cx + rCenter * COS(Angle)
	ADDY rCenter * SIN(Angle)
	ROTZ Angle
RETURN

"RightHotSpot":
	IF CurveRight[i] < ESP THEN 
		HOTSPOT Width[i]/2,  0,	0, unID, CurveRight[i], 1 : unID = unID + 1
		HOTSPOT Width[i]/2,  0, 0, unID, CurveRight[i], 2 : unID = unID + 1
		HOTSPOT Width[i]/2, -1,	0, unID, CurveRight[i], 3 : unID = unID + 1
	ENDIF
RETURN

"RightAngleHotSpot":
	IF CurveRight[i] < ESP THEN 
		HOTSPOT 0.5+Width[i]/2,  0,	0, unID, RightAngle[i], 1 : unID = unID + 1
		HOTSPOT 0.5+Width[i]/2,  0, 0, unID, RightAngle[i], 2 : unID = unID + 1
		HOTSPOT 0.5+Width[i]/2, -1,	0, unID, RightAngle[i], 3 : unID = unID + 1
	ENDIF
RETURN

"RightWidthHotSpot":
	IF CurveRight[i] < ESP THEN 
		HOTSPOT -0.5-Width[i]/2,  0, 0, unID, Width[i], 1 : unID = unID + 1
		HOTSPOT -0.5-Width[i]/2,  0, 0, unID, Width[i], 2 : unID = unID + 1
		HOTSPOT -0.5-Width[i]/2-1,  0, 0, unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftHotSpot":
	IF CurveLeft[i] < ESP THEN 
		HOTSPOT -Width[i]/2,  0, 0, unID, CurveLeft[i], 1 : unID = unID + 1
		HOTSPOT -Width[i]/2,  0, 0, unID, CurveLeft[i], 2 : unID = unID + 1
		HOTSPOT -Width[i]/2, -1, 0, unID, CurveLeft[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftAngleHotSpot":
	IF CurveLeft[i] < ESP THEN 
		HOTSPOT -0.5-Width[i]/2,  0, 0, unID, LeftAngle[i], 1 : unID = unID + 1
		HOTSPOT -0.5-Width[i]/2,  0, 0, unID, LeftAngle[i], 2 : unID = unID + 1
		HOTSPOT -0.5-Width[i]/2, -1, 0, unID, LeftAngle[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftWidthHotSpot":
	IF CurveLeft[i] < ESP THEN 
		HOTSPOT 0.5+Width[i]/2,  0,	0, unID, Width[i], 1 : unID = unID + 1
		HOTSPOT 0.5+Width[i]/2,  0, 0, unID, Width[i], 2 : unID = unID + 1
		HOTSPOT 0.5+Width[i]/2, -1,	0, unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"StraightHotSpot":
	HOTSPOT 0,  0,				0, unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT 0,  NextLength[i], 	0, unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT 0, -1,				0, unID, NextLength[i], 3 : unID = unID + 1
RETURN

"StraightHotSpot1":
	HOTSPOT 0,  0,				0, unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT 0,  1, 				0, unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT 0, -1,				0, unID, NextLength[i], 3 : unID = unID + 1
RETURN
]]>
