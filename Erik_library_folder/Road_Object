<Script_2D SectVersion="20" SectionFlags="0" SubIdent="0">
<![CDATA[
PEN 1
DIM StraightLength[100]
DIM CurvetWidth[100]
Orietation = 0
FOR i = 1 TO 100
	IF RightAngle[i] = 0 THEN RightAngle[i] = 90
NEXT i

FOR i = 1 TO 100
	IF LeftAngle[i] = 0 THEN LeftAngle[i] = 90
NEXT i

FOR i = 1 TO 100
    IF Width[i] <> 0 THEN Width[i] = MIN(14, MAX(3, Width[i]))
NEXT i

TempWidth = Width[1]
IF TempWidth = 0 THEN TempWidth = 7

h = 1
WHILE h <= 100 DO
	IF Width[h] > 0 AND Width[h] <> TempWidth THEN
		TempWidth = Width[h]
	ENDIF
	Width[h] = TempWidth
	h = h + 1
ENDWHILE

FOR i = 1 TO 100
	RightAngle[i] = MIN(180, MAX(0, RightAngle[i]))
	LeftAngle[i]  = MIN(180, MAX(0, LeftAngle[i]))
NEXT i

HOTSPOT2  -Width[1]/2,	0,	unID, Width[1], 1 : unID = unID + 1
HOTSPOT2   Width[1]/2,	0,	unID, Width[1], 2 : unID = unID + 1
HOTSPOT2  -10,			0,	unID, Width[1], 3 : unID = unID + 1

CurvetWidth[1] = Width[1]

i = 1
WHILE ObjectOrder[i] <> 0 DO
	IF ObjectOrder[i] = 1 THEN
		GOSUB "StraightHotSpot1"
		GOSUB "Straight1"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
	ENDIF
	IF NextLength[i] > 0 THEN ObjectOrder[i+1] = 2
	IF CurveLeft[i]  > 0 THEN ObjectOrder[i+1] = 3
	IF CurveRight[i] > 0 THEN ObjectOrder[i+1] = 4
	IF ObjectOrder[i] = 2 THEN
		GOSUB "Straight"
		GOSUB "RemoveHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	IF ObjectOrder[i] = 3 THEN
		GOSUB "CurveLeft"
		GOSUB "RemoveCornerHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "LeftAngleHotSpot"
		GOSUB "LeftWidthHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	IF ObjectOrder[i] = 4 THEN
		GOSUB "CurveRight"
		GOSUB "RemoveCornerHotSpot"
		GOSUB "RightHotSpot"
		GOSUB "RightAngleHotSpot"
		GOSUB "RightWidthHotSpot"
		GOSUB "LeftHotSpot"
		GOSUB "StraightHotSpot"
		GOTO "NextIter"
	ENDIF
	"NextIter":
	i = i + 1
ENDWHILE

TEXT2 0, -2, STR(TotalLength, 10, 3) + " m"

END

"Straight1":
	POLY2_ 4, 1+2+4,
		-Width[i]/2,	0,	1,
		 Width[i]/2,	0,	1,
		 Width[i]/2,	1, 	1,
		-Width[i]/2,	1,	1
	ADD2 0, 1
RETURN

"Straight":
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		POLY2_ 4, 1+2+4,
			-Width[i]/2,	0,				1,
			 Width[i]/2,	0,				1,
			 Width[i]/2,	NextLength[i-1],1,
			-Width[i]/2,	NextLength[i-1],1
		
		LINE2 0, 0,		0, NextLength[i-1]
	ENDIF

	TotalLength = TotalLength + NextLength[i-1]
	ADD2 0, NextLength[i-1]

	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"CurveRight":
	Angle = RightAngle[i]
	cx = Width[i-1]/2 + CurveRight[i-1]
	rCenter = CurveRight[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		IF Width[i] <= Width[i-1] THEN
			POLY2_ 8, 1+2+4,
				-Width[i-1]/2,										0,													1,
				 Width[i-1]/2,										0,													1,
				 Width[i-1]/2,										Width[i-1]-Width[i],								1,
				 cx,												Width[i-1]-Width[i], 								900,
				 cx - CurveRight[i-1] * COS(Angle), 				CurveRight[i-1] * SIN(Angle) + Width[i-1]-Width[i],	3001,
				 cx - (CurveRight[i-1] + Width[i-1]) * COS(Angle),	(CurveRight[i-1] + Width[i-1]) * SIN(Angle),		1,
				 cx,												0, 													900,
				-Width[i-1]/2,										0,													3001
			LINE2 0, 0,	
				  0, (Width[i-1]-Width[i])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 cx, (Width[i-1]-Width[i])/2,
				 cx, 180-Angle, 180
			TotalLength = TotalLength + (Angle * PI * ABS(cx) / 180)
		ELSE
			POLY2_ 7, 1+2+4,
				-Width[i-1]/2,										0,																	1,
				 Width[i-1]/2,										0,																	1,
				 cx,												0, 																	900,
				 cx - CurveRight[i-1] * COS(Angle), 				CurveRight[i-1] * SIN(Angle), 										3001,
				 cx - (CurveRight[i-1] + Width[i-1]) * COS(Angle),	(CurveRight[i-1] + Width[i-1]) * SIN(Angle) + Width[i] - Width[i-1],1,
				 cx,												Width[i] - Width[i-1], 												900,
				-Width[i-1]/2,										Width[i] - Width[i-1],												3001
			LINE2 0, 0,
				  0, (Width[i] - Width[i-1])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 cx, (Width[i] - Width[i-1])/2,
				 cx, Angle, 180
			TotalLength = TotalLength + (Angle * PI * ABS(cx) / 180)
			ADD2 0, Width[i] - Width[i-1]
		ENDIF
	ENDIF
	ADD2 cx - rCenter * COS(Angle), rCenter * SIN(Angle)
	ROT2 -Angle
	Orietation = Orietation - Angle
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"CurveLeft":
	Angle = LeftAngle[i]
	cx = -Width[i-1]/2 - CurveLeft[i-1]
	rCenter = CurveLeft[i-1] + Width[i]/2 + Width[i-1]-Width[i]
	IF ABS(RemovePart[i]) < Width[i]/2 THEN
		IF Width[i] <= Width[i-1] THEN
			POLY2_ 8, 1+2+4,
				 Width[i-1]/2,										0,													1,
				-Width[i-1]/2,										0,													1,
				-Width[i-1]/2,										Width[i-1]-Width[i],								1,
				 cx,												Width[i-1]-Width[i], 								900,
				 cx + CurveLeft[i-1] * COS(Angle), 				CurveLeft[i-1] * SIN(Angle) + Width[i-1]-Width[i],	3001,
				 cx + (CurveLeft[i-1] + Width[i-1]) * COS(Angle),	(CurveLeft[i-1] + Width[i-1]) * SIN(Angle),		1,
				 cx,												0, 													900,
				 Width[i-1]/2,										0,													3001
			LINE2 0, 0,
				  0, (Width[i-1] - Width[i])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 cx, (Width[i-1] - Width[i])/2,
				 -cx, 0, Angle
			TotalLength = TotalLength + (Angle * PI * ABS(cx) / 180)

		ELSE
			POLY2_ 7, 1+2+4,
				 Width[i-1]/2,										0,																	1,
				-Width[i-1]/2,										0,																	1,
				 cx,												0, 																	900,
				 cx + CurveLeft[i-1] * COS(Angle), 				CurveLeft[i-1] * SIN(Angle), 										3001,
				 cx + (CurveLeft[i-1] + Width[i-1]) * COS(Angle),	(CurveLeft[i-1] + Width[i-1]) * SIN(Angle) + Width[i] - Width[i-1],	1,
				 cx,												Width[i] - Width[i-1], 											900,
				 Width[i-1]/2,										Width[i] - Width[i-1],											3001
			LINE2 0, 0,	
				  0, (Width[i] - Width[i-1])/2
			TotalLength = TotalLength + ABS((Width[i-1]-Width[i])/2)
			ARC2 cx, (Width[i] - Width[i-1])/2,
				 -cx, 0, Angle
			TotalLength = TotalLength + (Angle * PI * ABS(cx) / 180)

			ADD2 0, Width[i] - Width[i-1]
		ENDIF
	ENDIF
	ADD2 cx + rCenter * COS(Angle), rCenter * SIN(Angle)
	ROT2 Angle
	Orietation = Orietation + Angle
	ROT2 Orietation
	ADD2 MoveX[i], MoveY[i]
	ROT2 -Orietation
RETURN

"RightHotSpot":
	!IF CurveRight[i] < ESP THEN
		HOTSPOT2  Width[i]/2,  0,	unID, CurveRight[i], 1 : unID = unID + 1
		HOTSPOT2  Width[i]/2,  0,	unID, CurveRight[i], 2 : unID = unID + 1
		HOTSPOT2  Width[i]/2, -1,	unID, CurveRight[i], 3 : unID = unID + 1
	!ENDIF
RETURN

"RightAngleHotSpot":
	IF CurveRight[i] < ESP AND Width[i] = Width[i-1] THEN
		HOTSPOT2  1+Width[i]/2,  0,	unID, RightAngle[i], 1 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2,  0,	unID, RightAngle[i], 2 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2, -1,	unID, RightAngle[i], 3 : unID = unID + 1
	ENDIF
RETURN

"RightWidthHotSpot":
	IF CurveRight[i] < ESP THEN
		HOTSPOT2 -1-Width[i]/2,   0,	unID, Width[i], 1 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2,   0,	unID, Width[i], 2 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2-1, 0,	unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftHotSpot":
	!IF CurveLeft[i] < ESP THEN
		HOTSPOT2 -Width[i]/2, 0,	unID, CurveLeft[i], 1 : unID = unID + 1
		HOTSPOT2 -Width[i]/2, 0,	unID, CurveLeft[i], 2 : unID = unID + 1
		HOTSPOT2 -Width[i]/2, -1,	unID, CurveLeft[i], 3 : unID = unID + 1
	!ENDIF
RETURN

"LeftAngleHotSpot":
	IF CurveLeft[i] < ESP AND Width[i] = Width[i-1] THEN
		HOTSPOT2 -1-Width[i]/2,  0,	unID, LeftAngle[i], 1 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2,  0,	unID, LeftAngle[i], 2 : unID = unID + 1
		HOTSPOT2 -1-Width[i]/2, -1,	unID, LeftAngle[i], 3 : unID = unID + 1
	ENDIF
RETURN

"LeftWidthHotSpot":
	IF CurveLeft[i] < ESP THEN
		HOTSPOT2  1+Width[i]/2,   0,	unID, Width[i], 1 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2,   0,	unID, Width[i], 2 : unID = unID + 1
		HOTSPOT2  1+Width[i]/2+1, 0,	unID, Width[i], 3 : unID = unID + 1
	ENDIF
RETURN

"StraightHotSpot":
	HOTSPOT2 0,  0,				unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT2 0,  NextLength[i],	unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT2 0, -1,				unID, NextLength[i], 3 : unID = unID + 1
RETURN

"StraightHotSpot1":
	HOTSPOT2 0,  0,	unID, NextLength[i], 1 : unID = unID + 1
	HOTSPOT2 0,  1,	unID, NextLength[i], 2 : unID = unID + 1
	HOTSPOT2 0, -1,	unID, NextLength[i], 3 : unID = unID + 1
RETURN

"RemoveHotSpot":
	HOTSPOT2  0,  NextLength[i]-1,	unID, RemovePart[i], 1 : unID = unID + 1
	HOTSPOT2  0,  NextLength[i]-1,	unID, RemovePart[i], 2 : unID = unID + 1
	HOTSPOT2 -1,  NextLength[i]-1,	unID, RemovePart[i], 3 : unID = unID + 1
	GOSUB "MoveSegmentHotSpot"
	IF ABS(RemovePart[i]) > Width[i]/2 THEN GOTO "NextIter"
RETURN

"RemoveCornerHotSpot":
	HOTSPOT2  0, -1,	unID, RemovePart[i], 1 : unID = unID + 1
	HOTSPOT2  0, -1,	unID, RemovePart[i], 2 : unID = unID + 1
	HOTSPOT2 -1, -1,	unID, RemovePart[i], 3 : unID = unID + 1
	GOSUB "MoveSegmentHotSpot"
	IF ABS(RemovePart[i]) > Width[i]/2 THEN GOTO "NextIter"
RETURN

"MoveSegmentHotSpot":
	IF ABS(RemovePart[i]) > Width[i]/2 THEN
		ROT2 RightAngle[i]
		ROT2 Orietation
		HOTSPOT2  0,    0,	unID, MoveY[i], 1 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveY[i], 2 : unID = unID + 1
		HOTSPOT2 -100,  0,	unID, MoveY[i], 3 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveX[i], 1 : unID = unID + 1
		HOTSPOT2  0,    0,	unID, MoveX[i], 2 : unID = unID + 1
		HOTSPOT2  0,  100,	unID, MoveX[i], 3 : unID = unID + 1
		ROT2 -Orietation
		DEL 2
	ENDIF
RETURN
]]>
