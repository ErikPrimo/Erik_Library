! 	cx = -Width/2 - CurveLeft[i-1]

! 	ARC2 cx,0,rIn,0,Angle
! 	ARC2 cx,0,rOut,0,Angle

! 	ADD2 cx + rCenter * COS(Angle), rCenter * SIN(Angle)
! 	ROT2 Angle
! RETURN


! "RightHotSpot_2D":
! 	IF CurveRight[i] < EPS THEN
! 		HOTSPOT2 Width/2,0,unID,CurveRight[i],1 : unID = unID + 1
! 		HOTSPOT2 Width/2,0,unID,CurveRight[i],2 : unID = unID + 1
! 		HOTSPOT2 Width/2,-1,unID,CurveRight[i],3 : unID = unID + 1
